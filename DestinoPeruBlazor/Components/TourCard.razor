@using DestinoPeruBlazor.Models

<article class="tour-card">
    <div class="tour-card-image" style="@ImageStyle">
        <span class="tour-card-badge">@Tour.Location</span>
        @if (Tour.Price > 0)
        {
            <span class="tour-card-price-tag">S/ @Tour.Price.ToString("N0")</span>
        }
    </div>
    <div class="tour-card-body">
        <h3>@Tour.Title</h3>
        <p class="tour-card-agency">
            <span class="agency-dot"></span>@Tour.AgencyName
        </p>
        <p class="tour-card-desc">@(Tour.Description.Length > 100 ? Tour.Description[..100] + "..." : Tour.Description)</p>
        <div class="tour-card-footer">
            <small class="tour-date">@Tour.Date.ToString("dd MMM yyyy")</small>
            <a class="btn btn-primary btn-sm tour-card-btn" href="tour/@Tour.Id">Ver tour</a>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public TourDto Tour { get; set; } = default!;

    private string ImageStyle => string.IsNullOrEmpty(Tour.ImageUrl)
        ? "background-image: linear-gradient(135deg, var(--dp-terracota), var(--dp-oro))"
        : $"background-image: url('{Tour.ImageUrl}')";
}
