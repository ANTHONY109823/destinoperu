@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using Microsoft.AspNetCore.Components.Forms
@inject ApiService Api
@inject ToastService Toast

<section class="ops-panel admin-ops-panel">
    @if (Dashboard is not null)
    {
        <div class="ops-metrics-strip">
            <div class="ops-metric-pill"><strong>@Dashboard.TotalTours</strong> tours</div>
            <div class="ops-metric-pill warn"><strong>@Dashboard.PendingReservations</strong> pendientes</div>
            <div class="ops-metric-pill"><strong>@Dashboard.ConfirmedReservations</strong> confirmadas</div>
            <div class="ops-metric-pill highlight"><strong>S/ @Dashboard.TotalRevenue.ToString("N0")</strong></div>
            @if (Dashboard.VendorSales.Count > 0)
            {
                <div class="ops-metric-pill"><strong>@Dashboard.VendorSales.Sum(v => v.Reservations)</strong> vendidos (equipo)</div>
            }
        </div>
    }

    <div class="ops-quick-actions">
        <a class="ops-action-card" href="/manifiesto" target="_blank">
            <span class="ops-action-icon">📋</span><strong>Manifiesto</strong>
        </a>
        <a class="ops-action-card" href="/checkout">
            <span class="ops-action-icon">📱</span><strong>Pagos QR</strong>
        </a>
        @if (CanManageTours)
        {
            <button type="button" class="ops-action-card ops-action-btn @(showAddTour ? "active" : "")" @onclick="() => showAddTour = !showAddTour">
                <span class="ops-action-icon">➕</span><strong>Nuevo tour</strong>
            </button>
        }
    </div>

    @if (showAddTour && CanManageTours)
    {
        <div class="dash-panel ops-add-tour-box">
            <h4>Agregar tour / salida</h4>
            <div class="admin-form-grid">
                <input class="form-control" placeholder="Título *" @bind="quickTour.Title" />
                <input class="form-control" placeholder="Departamento" @bind="quickTour.Department" />
                <input type="number" class="form-control" placeholder="Precio S/" @bind="quickTour.Price" />
                <input type="number" class="form-control" placeholder="Asientos bus" @bind="quickTour.Capacity" title="Total asientos del bus" />
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <InputFile OnChange="OnQuickTourPhoto" accept="image/*" class="form-control form-control-sm" style="max-width:200px" />
                @if (!string.IsNullOrEmpty(quickTour.ImageUrl))
                {
                    <img src="@CloudinaryHelper.Optimize(quickTour.ImageUrl, 80)" class="ops-thumb-preview" alt="" />
                }
            </div>
            <button type="button" class="btn btn-primary btn-sm" disabled="@addingTour" @onclick="PublishQuickTour">Publicar tour</button>
        </div>
    }

    <div class="ops-section">
        <div class="ops-section-head">
            <h4>Pagos pendientes</h4>
            <span class="ops-badge @(PendingCount > 0 ? "warn" : "ok")">@PendingCount</span>
        </div>
        @if (PendingCount == 0) { <p class="ops-empty">✓ Sin pagos por verificar.</p> }
        else
        {
            @foreach (var r in PendingReservations)
            {
                <div class="ops-payment-card">
                    <div><strong>@r.TourTitle</strong><p class="mb-0 text-muted small">@r.UserName · S/ @r.Total.ToString("N2")</p></div>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="() => OnApprove.InvokeAsync(r.Id)">Verificar</button>
                </div>
            }
        }
    </div>

    <div class="ops-section">
        <div class="ops-section-head">
            <h4>Inventario y asientos de bus</h4>
            <span class="text-muted small">@Tours.Count salidas · fotos editables</span>
        </div>
        @if (Tours.Count == 0)
        {
            <p class="ops-empty">Sin tours. Pulsa «Nuevo tour» para agregar la primera salida.</p>
        }
        else
        {
            <div class="ops-tour-compact-grid">
                @foreach (var t in Tours)
                {
                    var img = GetThumb(t);
                    var avail = GetCap(t.Id);
                    var sold = Math.Max(0, t.Capacity - avail);
                    var pct = t.Capacity > 0 ? (int)(100.0 * avail / t.Capacity) : 0;
                    var level = pct >= 60 ? "high" : pct >= 30 ? "mid" : "low";
                    <article class="ops-tour-compact">
                        <div class="ops-tour-compact-photo" style="background-image:url('@img')">
                            <label class="ops-photo-change-sm">
                                📷
                                <InputFile OnChange="e => OnTourPhoto(t.Id, e)" accept="image/*" class="ops-file-hidden" />
                            </label>
                        </div>
                        <div class="ops-tour-compact-body">
                            <h6>@t.Title</h6>
                            <p class="ops-tour-meta">@t.Department · S/ @t.Price.ToString("N0")</p>
                            <div class="ops-seat-stats">
                                <span class="ops-seat-stat sold"><strong>@sold</strong> vendidos</span>
                                <span class="ops-seat-stat avail"><strong>@avail</strong> libres</span>
                                <span class="ops-seat-stat total"><strong>@GetTotalSeats(t.Id)</strong> asientos bus</span>
                            </div>
                            <div class="inventory-bar inventory-bar-sm"><div class="inventory-bar-fill @level" style="width:@(pct)%"></div></div>
                            <div class="ops-seat-edit">
                                <label class="small">Libres</label>
                                <div class="ops-seat-row">
                                    <button type="button" class="btn-inv" @onclick="() => Adjust(t.Id, -1)">−</button>
                                    <input type="number" class="form-control form-control-sm" value="@avail" @onchange="e => SetAvail(t.Id, e)" min="0" max="@GetTotalSeats(t.Id)" />
                                    <button type="button" class="btn-inv" @onclick="() => Adjust(t.Id, 1)">+</button>
                                </div>
                                <label class="small">Total bus</label>
                                <input type="number" class="form-control form-control-sm" value="@GetTotalSeats(t.Id)" @onchange="e => SetTotalSeats(t.Id, e)" min="1" max="99" />
                                <button type="button" class="btn btn-primary btn-sm w-100 mt-1" @onclick="() => SaveTour(t.Id)">Guardar</button>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public AgencyDashboardDto? Dashboard { get; set; }
    [Parameter] public List<ReservationDto> PendingReservations { get; set; } = [];
    [Parameter] public List<AgencyTourListItemDto> Tours { get; set; } = [];
    [Parameter] public Dictionary<int, int> CapacityEdits { get; set; } = new();
    [Parameter] public Dictionary<int, int> TotalSeatEdits { get; set; } = new();
    [Parameter] public bool CanManageTours { get; set; }
    [Parameter] public EventCallback<int> OnApprove { get; set; }
    [Parameter] public EventCallback OnToursChanged { get; set; }

    private bool showAddTour;
    private bool addingTour;
    private CreateTourRequest quickTour = new() { Date = DateTime.Today.AddDays(14), AdventureType = "FullDay", Capacity = 28, Price = 99 };
    private int PendingCount => PendingReservations.Count;

    private int GetCap(int id) => CapacityEdits.TryGetValue(id, out var v) ? v : 0;
    private int GetTotalSeats(int id) => TotalSeatEdits.TryGetValue(id, out var v) ? v : Tours.FirstOrDefault(t => t.Id == id)?.Capacity ?? 0;

    private string GetThumb(AgencyTourListItemDto t) =>
        CloudinaryHelper.Optimize(
            string.IsNullOrWhiteSpace(t.ImageUrl) ? TourGalleryHelper.GetGalleryUrls(null, t.Slug).FirstOrDefault() ?? "" : t.ImageUrl,
            320);

    private void Adjust(int id, int delta)
    {
        var max = GetTotalSeats(id);
        CapacityEdits[id] = Math.Clamp(GetCap(id) + delta, 0, max);
    }

    private void SetAvail(int id, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            CapacityEdits[id] = Math.Clamp(v, 0, GetTotalSeats(id));
    }

    private void SetTotalSeats(int id, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1)
        {
            TotalSeatEdits[id] = v;
            if (GetCap(id) > v) CapacityEdits[id] = v;
        }
    }

    private async Task SaveTour(int tourId)
    {
        var r = await Api.UpdateTourItemAsync(tourId, availableCapacity: GetCap(tourId), busTotalSeats: GetTotalSeats(tourId));
        if (r.Success) { Toast.ShowSuccess("Asientos y cupos guardados."); await OnToursChanged.InvokeAsync(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task OnTourPhoto(int tourId, InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        await using var stream = file.OpenReadStream(4_000_000);
        var up = await Api.UploadImageAsync(stream, file.Name, "tours");
        if (up.Success && up.Data is not null)
        {
            var r = await Api.UpdateTourItemAsync(tourId, up.Data);
            if (r.Success) { Toast.ShowSuccess("Foto actualizada."); await OnToursChanged.InvokeAsync(); }
        }
        else Toast.ShowError(up.ErrorMessage ?? "Error");
    }

    private async Task OnQuickTourPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        await using var stream = file.OpenReadStream(4_000_000);
        var up = await Api.UploadImageAsync(stream, file.Name, "tours");
        if (up.Success && up.Data is not null) quickTour.ImageUrl = up.Data;
    }

    private async Task PublishQuickTour()
    {
        if (string.IsNullOrWhiteSpace(quickTour.Title)) { Toast.ShowWarning("Título obligatorio."); return; }
        if (string.IsNullOrWhiteSpace(quickTour.Description)) quickTour.Description = quickTour.Title;
        addingTour = true;
        var r = await Api.CreateAgencyTourAsync(quickTour);
        if (r.Success)
        {
            Toast.ShowSuccess("Tour publicado.");
            quickTour = new() { Date = DateTime.Today.AddDays(14), AdventureType = "FullDay", Capacity = 28, Price = 99 };
            showAddTour = false;
            await OnToursChanged.InvokeAsync();
        }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
        addingTour = false;
    }
}
