@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Components.UI
@using Microsoft.AspNetCore.Components.Forms
@inject ApiService Api
@inject ToastService Toast

<div class="tour-editor">
    <div class="tour-editor-bar">
        <div class="tour-editor-bar-title">
            <span class="tour-editor-eyebrow">@(TourId.HasValue ? "Editando" : "Nuevo tour")</span>
            <h2>@(string.IsNullOrWhiteSpace(titleStr) ? (TourId.HasValue ? "Tour sin título" : "Publicar tour nuevo") : titleStr)</h2>
        </div>
        <div class="tour-editor-bar-actions">
            <AppButton Variant="ghost" OnClick="OnCancelEdit">Cancelar</AppButton>
            <AppButton Variant="primary" Icon="💾" Loading="Saving" OnClick="Submit">@(TourId.HasValue ? "Guardar cambios" : "Publicar tour")</AppButton>
        </div>
    </div>

    <SectionCard Title="Información general">
        <div class="ds-form-grid">
            <FormField Label="Título del tour" Required="true" Placeholder="Ej: Full Day Laguna Humantay" @bind-Value="titleStr" />
            <FormField Label="Tipo de experiencia" Type="select" @bind-Value="typeStr">
                <option value="FullDay">Full Day</option>
                <option value="Paquete2D1N">Paquete 2D/1N</option>
                <option value="Cultural">Cultural</option>
                <option value="Trekking">Trekking</option>
                <option value="Aventura">Aventura</option>
            </FormField>
        </div>
        <FormField Label="Descripción" Type="textarea" Rows="4"
                   HelpText="Describe la experiencia: qué verán, por qué es especial."
                   Placeholder="Vive un día inolvidable rumbo a..." @bind-Value="descStr" />
    </SectionCard>

    <SectionCard Title="Ubicación">
        <div class="ds-form-grid">
            <FormField Label="Departamento" Placeholder="Cusco" @bind-Value="deptStr" />
            <FormField Label="Ciudad / destino" Placeholder="Soraypampa" @bind-Value="locStr" />
            <FormField Label="Punto de partida" Placeholder="Plaza de Armas de Cusco" @bind-Value="partidaStr" />
            <FormField Label="Punto de retorno" Placeholder="Plaza de Armas de Cusco" @bind-Value="retornoStr" />
        </div>
    </SectionCard>

    <SectionCard Title="Detalles del servicio">
        <div class="ds-form-grid">
            <FormField Label="Precio por persona (S/)" Type="number" Placeholder="120" @bind-Value="priceStr" />
            <FormField Label="Cupos / asientos del bus" Type="number" Placeholder="20" @bind-Value="capStr" />
            <FormField Label="Fecha de salida" Type="date" @bind-Value="dateStr" />
            <FormField Label="Hora de salida" Placeholder="05:30 AM" @bind-Value="horaSalidaStr" />
            <FormField Label="Duración aproximada" Placeholder="12 horas" @bind-Value="duracionStr" />
        </div>
    </SectionCard>

    <SectionCard Title="Itinerario">
        <FormField Label="Pasos del itinerario" Type="textarea" Rows="6"
                   HelpText="Una parada por línea. Formato: HH:MM - Actividad - Detalle (el detalle es opcional)."
                   Placeholder="05:30 - Recojo del hotel - Te esperamos en recepción&#10;07:00 - Desayuno en Mollepata&#10;09:00 - Caminata a la laguna"
                   @bind-Value="itinerarioText" />
    </SectionCard>

    <SectionCard Title="Qué incluye / qué no incluye">
        <div class="ds-form-grid">
            <FormField Label="Qué incluye" Type="textarea" Rows="5"
                       HelpText="Un ítem por línea."
                       Placeholder="Transporte turístico&#10;Desayuno y almuerzo&#10;Guía profesional"
                       @bind-Value="incluyeText" />
            <FormField Label="Qué NO incluye" Type="textarea" Rows="5"
                       HelpText="Un ítem por línea."
                       Placeholder="Entradas a la reserva&#10;Propinas&#10;Gastos personales"
                       @bind-Value="noIncluyeText" />
        </div>
        <FormField Label="Qué llevar" Type="textarea" Rows="4"
                   HelpText="Un ítem por línea."
                   Placeholder="Ropa abrigadora&#10;Bloqueador solar&#10;Agua y snacks"
                   @bind-Value="llevarText" />
    </SectionCard>

    <SectionCard Title="Galería de fotos">
        <FormField Label="URLs de imágenes" Type="textarea" Rows="4"
                   HelpText="Pega una URL por línea (máx. 8). La foto marcada con ★ será la principal."
                   Placeholder="https://...foto1.jpg&#10;https://...foto2.jpg"
                   @bind-Value="galeriaText" />

        @if (CloudinaryEnabled)
        {
            <div class="tour-editor-upload">
                <label class="ds-btn ds-btn-secondary">
                    📷 Subir foto
                    <InputFile OnChange="OnUploadPhoto" accept="image/*" class="ds-file-hidden" />
                </label>
                @if (uploading) { <span class="text-muted small">Subiendo...</span> }
            </div>
        }

        @{
            var urls = ParseLines(galeriaText).Take(8).ToList();
        }
        @if (urls.Count > 0)
        {
            <div class="tour-editor-gallery">
                @foreach (var url in urls)
                {
                    var u = url;
                    <div class="tour-editor-thumb @(u == imageUrlStr ? "is-main" : "")">
                        <div class="tour-editor-thumb-img" style="background-image:url('@CloudinaryHelper.Optimize(u, 200)')"></div>
                        @if (u == imageUrlStr) { <span class="tour-editor-thumb-main">★ Principal</span> }
                        <div class="tour-editor-thumb-actions">
                            <button type="button" title="Marcar principal" @onclick="() => imageUrlStr = u">★</button>
                            <button type="button" title="Eliminar" @onclick="() => RemoveGalleryUrl(u)">✕</button>
                        </div>
                    </div>
                }
            </div>
        }
    </SectionCard>

    <div class="tour-editor-footer">
        <AppButton Variant="ghost" OnClick="OnCancelEdit">Cancelar</AppButton>
        <AppButton Variant="primary" Icon="💾" Loading="Saving" OnClick="Submit">@(TourId.HasValue ? "Guardar cambios" : "Publicar tour")</AppButton>
    </div>
</div>

@code {
    [Parameter] public int? TourId { get; set; }
    [Parameter] public CreateTourRequest Model { get; set; } = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };
    [Parameter] public bool Saving { get; set; }
    [Parameter] public EventCallback<CreateTourRequest> OnSave { get; set; }
    [Parameter] public EventCallback OnCancelEdit { get; set; }

    private string titleStr = "";
    private string descStr = "";
    private string typeStr = "FullDay";
    private string deptStr = "";
    private string locStr = "";
    private string partidaStr = "";
    private string retornoStr = "";
    private string priceStr = "";
    private string capStr = "";
    private string dateStr = "";
    private string horaSalidaStr = "";
    private string duracionStr = "";
    private string imageUrlStr = "";
    private string itinerarioText = "";
    private string incluyeText = "";
    private string noIncluyeText = "";
    private string llevarText = "";
    private string galeriaText = "";

    private bool uploading;
    private int _loadedFor = -2;

    private bool CloudinaryEnabled => true;

    protected override void OnParametersSet()
    {
        var key = TourId ?? -1;
        if (_loadedFor == key) return;
        _loadedFor = key;

        titleStr = Model.Title;
        descStr = Model.Description;
        typeStr = string.IsNullOrWhiteSpace(Model.AdventureType) ? "FullDay" : Model.AdventureType;
        deptStr = Model.Department;
        locStr = Model.Location;
        partidaStr = Model.PuntoPartida ?? "";
        retornoStr = Model.PuntoRetorno ?? "";
        priceStr = Model.Price > 0 ? Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture) : "";
        capStr = Model.Capacity > 0 ? Model.Capacity.ToString() : "";
        dateStr = (Model.Date == default ? DateTime.Today.AddDays(7) : Model.Date).ToString("yyyy-MM-dd");
        horaSalidaStr = Model.HoraSalida ?? "";
        duracionStr = Model.DuracionAproximada ?? "";

        var galeria = Model.Galeria?.ToList() ?? [];
        if (galeria.Count == 0 && !string.IsNullOrWhiteSpace(Model.ImageUrl)) galeria.Add(Model.ImageUrl);
        galeriaText = string.Join("\n", galeria);
        imageUrlStr = string.IsNullOrWhiteSpace(Model.ImageUrl) ? (galeria.FirstOrDefault() ?? "") : Model.ImageUrl;

        itinerarioText = string.Join("\n", (Model.Itinerario ?? []).Select(FormatStep));
        incluyeText = string.Join("\n", Model.QueIncluye ?? []);
        noIncluyeText = string.Join("\n", Model.QueNoIncluye ?? []);
        llevarText = string.Join("\n", Model.QueLlevar ?? []);
    }

    private static string FormatStep(TourItineraryStepDto s)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(s.Hora)) parts.Add(s.Hora.Trim());
        if (!string.IsNullOrWhiteSpace(s.Titulo)) parts.Add(s.Titulo.Trim());
        if (!string.IsNullOrWhiteSpace(s.Descripcion)) parts.Add(s.Descripcion.Trim());
        return string.Join(" - ", parts);
    }

    private static List<string> ParseLines(string? text) =>
        (text ?? "")
            .Replace("\r\n", "\n").Replace('\r', '\n')
            .Split('\n')
            .Select(l => l.Trim())
            .Where(l => l.Length > 0)
            .ToList();

    private static List<TourItineraryStepDto> ParseItinerary(string? text) =>
        ParseLines(text).Select(line =>
        {
            var parts = line.Split(" - ", 3, StringSplitOptions.None);
            if (parts.Length == 1)
                return new TourItineraryStepDto { Titulo = parts[0].Trim() };
            return new TourItineraryStepDto
            {
                Hora = parts[0].Trim(),
                Titulo = parts.Length > 1 ? parts[1].Trim() : "",
                Descripcion = parts.Length > 2 ? parts[2].Trim() : ""
            };
        }).ToList();

    private void RemoveGalleryUrl(string url)
    {
        var urls = ParseLines(galeriaText).Where(u => u != url).ToList();
        galeriaText = string.Join("\n", urls);
        if (imageUrlStr == url) imageUrlStr = urls.FirstOrDefault() ?? "";
    }

    private async Task OnUploadPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        var urls = ParseLines(galeriaText);
        if (urls.Count >= 8) { Toast.ShowWarning("Máximo 8 fotos."); return; }
        uploading = true;
        try
        {
            await using var stream = file.OpenReadStream(5_000_000);
            var up = await Api.UploadImageAsync(stream, file.Name, "tours");
            if (up.Success && up.Data is not null)
            {
                urls.Add(up.Data);
                galeriaText = string.Join("\n", urls);
                if (string.IsNullOrWhiteSpace(imageUrlStr)) imageUrlStr = up.Data;
                Toast.ShowSuccess("Foto subida.");
            }
            else Toast.ShowError(up.ErrorMessage ?? "No se pudo subir la foto.");
        }
        finally { uploading = false; }
    }

    private async Task Submit()
    {
        Model.Title = titleStr.Trim();
        Model.Description = descStr.Trim();
        Model.AdventureType = typeStr;
        Model.Department = deptStr.Trim();
        Model.Location = locStr.Trim();
        Model.PuntoPartida = string.IsNullOrWhiteSpace(partidaStr) ? null : partidaStr.Trim();
        Model.PuntoRetorno = string.IsNullOrWhiteSpace(retornoStr) ? null : retornoStr.Trim();
        Model.HoraSalida = string.IsNullOrWhiteSpace(horaSalidaStr) ? null : horaSalidaStr.Trim();
        Model.DuracionAproximada = string.IsNullOrWhiteSpace(duracionStr) ? null : duracionStr.Trim();

        Model.Price = decimal.TryParse(priceStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var p) ? p : 0;
        Model.Capacity = int.TryParse(capStr, out var c) && c > 0 ? c : 1;
        Model.Date = DateTime.TryParse(dateStr, out var dt) ? dt : DateTime.Today.AddDays(7);

        Model.Itinerario = ParseItinerary(itinerarioText);
        Model.QueIncluye = ParseLines(incluyeText);
        Model.QueNoIncluye = ParseLines(noIncluyeText);
        Model.QueLlevar = ParseLines(llevarText);

        var galeria = ParseLines(galeriaText).Take(8).ToList();
        Model.Galeria = galeria;
        Model.ImageUrl = !string.IsNullOrWhiteSpace(imageUrlStr) && galeria.Contains(imageUrlStr)
            ? imageUrlStr
            : galeria.FirstOrDefault();

        await OnSave.InvokeAsync(Model);
    }
}
