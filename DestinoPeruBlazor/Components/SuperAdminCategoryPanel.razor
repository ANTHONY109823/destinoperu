@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject IJSRuntime JS
@inject ToastService Toast

@if (Category is null)
{
    <p class="text-muted">Categoría no válida.</p>
}
else
{
    <header class="sa-header sa-header-category">
        <div>
            <span class="sa-cat-pill">@Category.Icon @Category.Label</span>
            <h1 class="dashboard-title mb-1">Administración — @Category.Label</h1>
            <p class="text-muted mb-0">@Category.AdminHint</p>
        </div>
        <a class="btn btn-outline-secondary btn-sm" href="/superadmin/inicio">← Panel de control Inicio</a>
    </header>

    @if (CategoryMetrics is not null)
    {
        <div class="metrics-grid metrics-grid-compact">
            <div class="metric-card"><span class="metric-value">@CategoryMetrics.Partners</span><span class="metric-label">Socios @Category.Label</span></div>
            <div class="metric-card"><span class="metric-value">@CategoryMetrics.ActiveItems</span><span class="metric-label">Activos</span></div>
            <div class="metric-card metric-warn"><span class="metric-value">@CategoryMetrics.PendingPartners</span><span class="metric-label">Pendientes</span></div>
            <div class="metric-card"><span class="metric-value">@CategoryMetrics.Reservations</span><span class="metric-label">Reservas</span></div>
            <div class="metric-card metric-highlight"><span class="metric-value">S/ @CategoryMetrics.Revenue.ToString("N0")</span><span class="metric-label">Recaudado</span></div>
        </div>
    }

    <div class="panel-tabs sa-tabs" role="tablist">
        <button type="button" role="tab" class="panel-tab @(ActiveTab == "partners" ? "active" : "")" @onclick='() => SelectTabAsync("partners")'>Socios (@Partners.Count())</button>
        <button type="button" role="tab" class="panel-tab @(ActiveTab == "ranking" ? "active" : "")" @onclick='() => SelectTabAsync("ranking")'>Ranking</button>
        <button type="button" role="tab" class="panel-tab @(ActiveTab == "create" ? "active" : "")" @onclick='() => SelectTabAsync("create")'>+ Nuevo @Category.Label</button>
        <button type="button" role="tab" class="panel-tab @(ActiveTab == "config" ? "active" : "")" @onclick='() => SelectTabAsync("config")'>Configuración rubro</button>
    </div>

    @if (ActiveTab == "partners")
    {
        @if (!Partners.Any())
        {
            <div class="dash-panel text-center py-4">
                <p class="text-muted">No hay socios de @Category.Label registrados.</p>
                <button type="button" class="btn btn-primary" @onclick='() => SelectTabAsync("create")'>Crear primer perfil / agencia</button>
            </div>
        }
        else
        {
            <div class="partner-cards-grid">
                @foreach (var p in Partners)
                {
                    <article class="partner-card">
                        <div class="partner-card-top">
                            <span class="partner-cat-badge">@(Category?.Icon) @(Category?.Label)</span>
                            <span class="badge-status @(p.Status == "Approved" ? "ok" : "")">@p.Status</span>
                        </div>
                        <h3>@p.Name</h3>
                        <p class="partner-card-meta">RUC @p.RUC · @(string.IsNullOrWhiteSpace(p.OperatingDepartment) ? "—" : p.OperatingDepartment)</p>
                        <p class="partner-card-admin">👤 @p.AdminName<br /><small>@p.AdminEmail</small></p>
                        <div class="partner-card-stats">
                            <span>@p.StaffCount/5 vendedores</span>
                            <span>@p.ItemCount publicaciones</span>
                            <span class="partner-revenue">S/ @p.Revenue.ToString("N0")</span>
                        </div>
                        <div class="partner-card-actions">
                            <button type="button" class="btn btn-primary btn-sm" disabled="@(p.AdminUserId <= 0)"
                                    @onclick="() => ClickImpersonate(p.AdminUserId)">Entrar al panel</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => ClickStaff(p)">Equipo</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => ClickEdit(p)">Editar</button>
                            @if (p.Status != "Suspended")
                            {
                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => ClickSuspend(p)">Suspender</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-success btn-sm" @onclick="() => ClickReactivate(p)">Reactivar</button>
                            }
                            @if (Category?.Key == SuperAdminCategories.Tours)
                            {
                                <button type="button" class="btn btn-danger btn-sm" @onclick="() => ClickDelete(p)">Eliminar agencia</button>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        @ChildContent
    }
    else if (ActiveTab == "ranking")
    {
        <div class="partner-table-wrap mt-2">
            @if (!RankingRows.Any()) { <p class="text-muted">Sin ranking en @Category.Label.</p> }
            else
            {
                <div class="d-flex justify-content-end mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="DownloadRankingCsv">
                        ⬇ Descargar ranking (CSV)
                    </button>
                </div>
                <table class="partner-table">
                    <thead><tr><th>#</th><th>Socio</th><th>Recaudado</th><th>Reservas</th><th>Publicaciones</th></tr></thead>
                    <tbody>
                        @{ var n = 0; }
                        @foreach (var row in RankingRows)
                        {
                            n++;
                            <tr><td>@n</td><td>@row.Name</td><td>S/ @row.Revenue.ToString("N0")</td><td>@row.Reservations</td><td>@row.TourCount</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    else if (ActiveTab == "create")
    {
        <section class="dash-panel create-profile-panel">
            <h3>Crear agencia / socio — @Category.Label</h3>
            <p class="text-muted small">Registra un nuevo perfil de @Category.Label con su administrador (máx. 5 vendedores por socio).</p>
            @CreateForm
        </section>
    }
    else if (ActiveTab == "config")
    {
        <section class="dash-panel">
            <h3>Configuración — @Category.Label</h3>
            <ul>
                <li>Comisión plataforma: <strong>10%</strong></li>
                <li>@Category.ConfigNote</li>
            </ul>
        </section>
    }
}

@code {
    [Parameter] public SuperAdminCategory? Category { get; set; }
    [Parameter] public CategoryMetricsDto? CategoryMetrics { get; set; }
    [Parameter] public IEnumerable<PartnerListItemDto> Partners { get; set; } = [];
    [Parameter] public IEnumerable<AgencyRankingDto> RankingRows { get; set; } = [];
    [Parameter] public string Tab { get; set; } = "partners";
    [Parameter] public EventCallback<string> TabChanged { get; set; }
    [Parameter] public RenderFragment? CreateForm { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<int> OnImpersonate { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnShowStaff { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnEdit { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnSuspend { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnReactivate { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnDelete { get; set; }

    private string ActiveTab => NormalizeTab(Tab);

    private static string NormalizeTab(string? tab) => tab switch
    {
        "ranking" or "create" or "config" or "partners" => tab,
        _ => "partners"
    };

    private async Task SelectTabAsync(string tab)
    {
        tab = NormalizeTab(tab);
        if (ActiveTab == tab) return;
        await TabChanged.InvokeAsync(tab);
    }

    private async Task ClickImpersonate(int userId) => await OnImpersonate.InvokeAsync(userId);
    private async Task ClickStaff(PartnerListItemDto p) => await OnShowStaff.InvokeAsync(p);
    private async Task ClickEdit(PartnerListItemDto p) => await OnEdit.InvokeAsync(p);
    private async Task ClickSuspend(PartnerListItemDto p) => await OnSuspend.InvokeAsync(p);
    private async Task ClickReactivate(PartnerListItemDto p) => await OnReactivate.InvokeAsync(p);
    private async Task ClickDelete(PartnerListItemDto p) => await OnDelete.InvokeAsync(p);

    private async Task DownloadRankingCsv()
    {
        if (Category is null || !RankingRows.Any()) return;
        var rows = RankingRows.Select((r, i) => new[] { (i + 1).ToString(), r.Name, r.Revenue.ToString("F2"), r.Reservations.ToString(), r.TourCount.ToString() });
        var csv = CsvExportHelper.ToCsv(rows, "#,Socio,Recaudado S/,Reservas,Publicaciones");
        var file = $"ranking-{CsvExportHelper.SafeFileName(Category.Key)}-{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("destinoPeruDownload.csv", file, csv);
        Toast.ShowSuccess("Ranking descargado.");
    }
}
