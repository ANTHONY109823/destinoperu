@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject IJSRuntime JS
@inject ToastService Toast

@if (Category is null)
{
    <p class="text-muted">Categoría no válida.</p>
}
else
{
    <PageHeader Title="@($"Administración — {Category.Label}")" Subtitle="@Category.AdminHint" ShowBack="true" BackText="Panel de control" OnBack="GoInicio" />

    @if (CategoryMetrics is not null)
    {
        <div class="ds-metrics-grid sa-metrics-5">
            <MetricCard Value="@CategoryMetrics.Partners.ToString()" Label="@($"{Category.PartnerNounPlural}")" Icon="@Category.Icon" />
            <MetricCard Value="@CategoryMetrics.ActiveItems.ToString()" Label="Publicaciones activas" Icon="✅" />
            <MetricCard Value="@CategoryMetrics.PendingPartners.ToString()" Label="Pendientes" Icon="⏳" />
            <MetricCard Value="@CategoryMetrics.Reservations.ToString()" Label="Reservas" Icon="📋" />
            <MetricCard Value="@($"S/ {CategoryMetrics.Revenue.ToString("N0")}")" Label="Recaudado" Icon="💰" />
        </div>
    }

    <TabBar Tabs="Tabs" Active="ActiveTab" OnTabChange="SelectTabAsync" />

    @if (ActiveTab == "partners")
    {
        @if (!Partners.Any())
        {
            <DestinoPeruBlazor.Components.UI.EmptyState Icon="@Category.Icon"
                Title="@($"Sin {Category.PartnerNounPlural.ToLower()} registrados")"
                Message="@($"Crea el primer perfil de {Category.PartnerNoun} para empezar.")">
                <Action><AppButton Variant="primary" Icon="➕" OnClick='@(() => SelectTabAsync("create"))'>@($"Crear {Category.PartnerNoun}")</AppButton></Action>
            </DestinoPeruBlazor.Components.UI.EmptyState>
        }
        else
        {
            <div class="sa-partner-grid">
                @foreach (var p in Partners)
                {
                    <AppCard Class="sa-partner-card">
                        <div class="sa-partner-top">
                            <h3>@p.Name</h3>
                            <Badge Variant="@StatusVariant(p.Status)">@StatusLabel(p.Status)</Badge>
                        </div>
                        <p class="sa-partner-meta">RUC @p.RUC · @(string.IsNullOrWhiteSpace(p.OperatingDepartment) ? "—" : p.OperatingDepartment)</p>
                        <p class="sa-partner-admin">👤 @p.AdminName <span>· @p.AdminEmail</span></p>
                        <div class="sa-partner-stats">
                            <span><strong>@p.StaffCount</strong>/5 vendedores</span>
                            <span><strong>@p.ItemCount</strong> publicaciones</span>
                            <span class="sa-partner-rev">S/ @p.Revenue.ToString("N0")</span>
                        </div>
                        <div class="sa-partner-actions">
                            <AppButton Variant="primary" Icon="🚪" Disabled="@(p.AdminUserId <= 0)" OnClick="@(() => ClickImpersonate(p.AdminUserId))">Entrar al panel</AppButton>
                            <AppButton Variant="secondary" Icon="👥" OnClick="@(() => ClickStaff(p))">Equipo</AppButton>
                            <AppButton Variant="secondary" Icon="✏️" OnClick="@(() => ClickEdit(p))">Editar</AppButton>
                            @if (p.Status != "Suspended")
                            {
                                <AppButton Variant="ghost" OnClick="@(() => ClickSuspend(p))">Suspender</AppButton>
                            }
                            else
                            {
                                <AppButton Variant="ghost" OnClick="@(() => ClickReactivate(p))">Reactivar</AppButton>
                            }
                            @if (Category?.Key == SuperAdminCategories.Tours)
                            {
                                <AppButton Variant="danger" Icon="🗑️" OnClick="@(() => ClickDelete(p))">Eliminar agencia</AppButton>
                            }
                        </div>
                    </AppCard>
                }
            </div>
        }
        @ChildContent
    }
    else if (ActiveTab == "ranking")
    {
        <SectionCard Title="@($"Ranking de {Category.PartnerNounPlural.ToLower()}")" Subtitle="Ordenado por recaudación.">
            <HeaderAction>
                @if (RankingRows.Any())
                {
                    <AppButton Variant="secondary" Icon="⬇️" OnClick="DownloadRankingCsv">Descargar ranking CSV</AppButton>
                }
            </HeaderAction>
            <ChildContent>
                @if (!RankingRows.Any())
                {
                    <p class="text-muted mb-0">Sin ranking en @Category.Label.</p>
                }
                else
                {
                    <div class="partner-table-wrap">
                        <table class="partner-table">
                            <thead><tr><th>#</th><th>Socio</th><th>Recaudado</th><th>Reservas</th><th>Publicaciones</th></tr></thead>
                            <tbody>
                                @{ var n = 0; }
                                @foreach (var row in RankingRows)
                                {
                                    n++;
                                    <tr><td>@n</td><td>@row.Name</td><td>S/ @row.Revenue.ToString("N0")</td><td>@row.Reservations</td><td>@row.TourCount</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </ChildContent>
        </SectionCard>
    }
    else if (ActiveTab == "create")
    {
        <SectionCard Title="@($"Crear {Category.PartnerNoun}")"
                     Subtitle="@($"Registra un nuevo perfil de {Category.PartnerNoun} con su administrador (hasta 5 vendedores).")">
            @CreateForm
        </SectionCard>
    }
    else if (ActiveTab == "config")
    {
        <SectionCard Title="@($"Configuración — {Category.Label}")">
            <ul class="sa-config-list">
                <li>Comisión de la plataforma: <strong>10%</strong></li>
                <li>@Category.ConfigNote</li>
            </ul>
        </SectionCard>
    }
}

@code {
    [Parameter] public SuperAdminCategory? Category { get; set; }
    [Parameter] public CategoryMetricsDto? CategoryMetrics { get; set; }
    [Parameter] public IEnumerable<PartnerListItemDto> Partners { get; set; } = [];
    [Parameter] public IEnumerable<AgencyRankingDto> RankingRows { get; set; } = [];
    [Parameter] public string Tab { get; set; } = "partners";
    [Parameter] public EventCallback<string> TabChanged { get; set; }
    [Parameter] public RenderFragment? CreateForm { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<int> OnImpersonate { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnShowStaff { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnEdit { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnSuspend { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnReactivate { get; set; }
    [Parameter] public EventCallback<PartnerListItemDto> OnDelete { get; set; }
    [Parameter] public EventCallback OnGoInicio { get; set; }

    private string ActiveTab => NormalizeTab(Tab);

    private IReadOnlyList<TabBar.TabItem> Tabs =>
    [
        new("partners", Category?.PartnerNounPlural ?? "Socios", Partners.Count(), "🤝"),
        new("ranking", "Ranking", null, "🏆"),
        new("create", $"Crear {Category?.PartnerNoun ?? "socio"}", null, "➕"),
        new("config", "Configuración", null, "⚙️")
    ];

    private static string StatusVariant(string s) => s switch
    {
        "Approved" or "Active" => "success",
        "Pending" => "warning",
        "Suspended" => "neutral",
        _ => "info"
    };
    private static string StatusLabel(string s) => s switch
    {
        "Approved" => "Aprobada",
        "Active" => "Activa",
        "Pending" => "Pendiente",
        "Suspended" => "Suspendida",
        _ => s
    };

    private static string NormalizeTab(string? tab) => tab switch
    {
        "ranking" or "create" or "config" or "partners" => tab,
        _ => "partners"
    };

    private async Task SelectTabAsync(string tab)
    {
        tab = NormalizeTab(tab);
        if (ActiveTab == tab) return;
        await TabChanged.InvokeAsync(tab);
    }

    private async Task GoInicio() => await OnGoInicio.InvokeAsync();
    private async Task ClickImpersonate(int userId) => await OnImpersonate.InvokeAsync(userId);
    private async Task ClickStaff(PartnerListItemDto p) => await OnShowStaff.InvokeAsync(p);
    private async Task ClickEdit(PartnerListItemDto p) => await OnEdit.InvokeAsync(p);
    private async Task ClickSuspend(PartnerListItemDto p) => await OnSuspend.InvokeAsync(p);
    private async Task ClickReactivate(PartnerListItemDto p) => await OnReactivate.InvokeAsync(p);
    private async Task ClickDelete(PartnerListItemDto p) => await OnDelete.InvokeAsync(p);

    private async Task DownloadRankingCsv()
    {
        if (Category is null || !RankingRows.Any()) return;
        var rows = RankingRows.Select((r, i) => new[] { (i + 1).ToString(), r.Name, r.Revenue.ToString("F2"), r.Reservations.ToString(), r.TourCount.ToString() });
        var csv = CsvExportHelper.ToCsv(rows, "#,Socio,Recaudado S/,Reservas,Publicaciones");
        var file = $"ranking-{CsvExportHelper.SafeFileName(Category.Key)}-{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("destinoPeruDownload.csv", file, csv);
        Toast.ShowSuccess("Ranking descargado.");
    }
}
