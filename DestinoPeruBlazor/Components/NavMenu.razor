@using DestinoPeruBlazor.Services
@inject AuthStateService Auth
@inject NavigationManager Nav
@implements IDisposable

<header class="dp-nav" style="background: linear-gradient(135deg, #00332a 0%, #004D40 100%);">
    <div class="dp-nav-inner container">
        <a class="dp-brand" href="/" @onclick="CloseMenu">
            <span class="dp-brand-text">Destino<strong>Perú</strong></span>
        </a>

        <button class="dp-nav-toggle @(menuOpen ? "open" : "")"
                @onclick="ToggleMenu"
                aria-expanded="@menuOpen"
                aria-controls="dp-nav-menu"
                aria-label="Abrir menú">
            <span></span><span></span><span></span>
        </button>

        <nav id="dp-nav-menu" class="dp-nav-links @(menuOpen ? "open" : "")">
            <NavLink class="dp-link" href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">Tours</NavLink>
            <NavLink class="dp-link" href="/hoteles" @onclick="CloseMenu">Hoteles</NavLink>
            <NavLink class="dp-link" href="/restaurantes" @onclick="CloseMenu">Restaurantes</NavLink>
            <NavLink class="dp-link" href="/cafes-bar" @onclick="CloseMenu">Cafés / Bar</NavLink>

            @if (Auth.IsAuthenticated)
            {
                <NavLink class="dp-link" href="/mis-reservas" @onclick="CloseMenu">Mis reservas</NavLink>
                @if (Auth.Role == "SuperAdmin")
                {
                    <NavLink class="dp-link" href="/superadmin" @onclick="CloseMenu">Super Admin</NavLink>
                }
                @if (Auth.Role is "Admin" or "SuperAdmin")
                {
                    <NavLink class="dp-link" href="/admin" @onclick="CloseMenu">Mi agencia</NavLink>
                }
                @if (Auth.Role == "Vendedor")
                {
                    <NavLink class="dp-link" href="/vendedor" @onclick="CloseMenu">Vendedor</NavLink>
                }
                @if (Auth.Role == "Agencia")
                {
                    <NavLink class="dp-link" href="/partner" @onclick="CloseMenu">Partner</NavLink>
                }
            }

            @if (!Auth.IsAuthenticated)
            {
                <NavLink class="dp-link" href="/login" @onclick="CloseMenu">Ingresar</NavLink>
                <NavLink class="dp-link dp-link-register" href="/register" @onclick="CloseMenu">Registrarse</NavLink>
            }
            else
            {
                <NavLink class="dp-link" href="/login" @onclick="CloseMenu">Mi cuenta</NavLink>
                <span class="dp-user">Hola, @Auth.Name</span>
                <button type="button" class="btn btn-nav-outline btn-sm" @onclick="Logout">Salir</button>
            }
        </nav>
    </div>
</header>

@code {
    private bool menuOpen;

    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        CloseMenu();
        Nav.NavigateTo("/");
    }

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
