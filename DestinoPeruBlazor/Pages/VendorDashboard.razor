@page "/vendedor"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Panel Vendedor - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />

    @if (!Auth.IsAuthenticated || Auth.Role != "Vendedor")
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🔒" Title="Acceso para vendedores" Message="Inicia sesión con tu cuenta de vendedor.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando...</p>
    }
    else
    {
        <AgencyBrandHeader Profile="profile" Subtitle="@($"Vendedor: {Auth.Name} — inventario, pagos y manifiesto")" />

        @if (dashboard is not null)
        {
            <div class="ds-metrics-grid sa-metrics-5" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr));">
                <MetricCard Value="@((mySales?.Reservations ?? 0).ToString())" Label="Mis reservas" Icon="📋" />
                <MetricCard Value="@($"S/ {mySales?.Revenue.ToString("N0") ?? "0"}")" Label="Mi recaudado" Icon="💰" />
                <MetricCard Value="@pendingCount.ToString()" Label="Pagos pendientes" Icon="⏳" />
            </div>
        }

        <TabBar Tabs="Tabs" Active="tab" OnTabChange="@(t => tab = t)" />

        @if (tab == "payments")
        {
            <SectionCard Title="Validar Yape / Plin" Subtitle="Aprueba los pagos verificados de tus clientes.">
                @if (pendingCount == 0)
                {
                    <DestinoPeruBlazor.Components.UI.EmptyState Icon="✅" Title="Todo al día" Message="No hay pagos pendientes por verificar." />
                }
                else
                {
                    @foreach (var r in reservations.Where(x => x.Status == "Pending"))
                    {
                        <div class="sa-staff-row">
                            <div><strong>@r.TourTitle</strong><br /><span class="text-muted small">@r.UserName · S/ @r.Total.ToString("N2")</span></div>
                            <AppButton Variant="primary" Icon="✓" OnClick="@(() => Approve(r.Id))">Verificar y aprobar</AppButton>
                        </div>
                    }
                }
            </SectionCard>
        }
        else if (tab == "manifest")
        {
            <SectionCard Title="Manifiesto de pasajeros" Subtitle="Vista legal imprimible con DNI y punto de recojo.">
                <AppButton Variant="primary" Icon="📋" OnClick="@(() => Nav.NavigateTo("/manifiesto"))">Abrir manifiesto — CSV / PDF</AppButton>
            </SectionCard>
        }
        else
        {
            <AdminOperationsPanel Dashboard="dashboard"
                                  Tours="agencyTours"
                                  PendingReservations="PendingReservations"
                                  CapacityEdits="capacityEdits"
                                  TotalSeatEdits="totalSeatEdits"
                                  CanManageTours="false"
                                  OnApprove="Approve"
                                  OnToursChanged="ReloadTours" />
        }
    }
</div>

@code {
    private AgencyProfileDto? profile;
    private AgencyDashboardDto? dashboard;
    private List<ReservationDto> reservations = [];
    private List<AgencyTourListItemDto> agencyTours = [];
    private Dictionary<int, int> capacityEdits = new();
    private Dictionary<int, int> totalSeatEdits = new();
    private VendorSalesDto? mySales;
    private string tab = "payments";
    private bool loading = true;
    private int pendingCount;
    private List<ReservationDto> PendingReservations => reservations.Where(x => x.Status == "Pending").ToList();

    private IReadOnlyList<TabBar.TabItem> Tabs =>
    [
        new("payments", "Pagos", pendingCount, "💳"),
        new("manifest", "Manifiesto", null, "📋"),
        new("inventory", "Inventario", null, "⚙️")
    ];

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "Vendedor") { loading = false; return; }

        var pr = await Api.GetAgencyProfileAsync();
        if (pr.Success) profile = pr.Data;

        var d = await Api.GetAgencyDashboardAsync();
        if (d.Success) dashboard = d.Data;
        mySales = dashboard?.VendorSales.FirstOrDefault(v => v.UserId == Auth.UserId);

        var r = await Api.GetAgencyReservationsAsync();
        if (r.Success && r.Data is not null)
        {
            reservations = r.Data;
            pendingCount = reservations.Count(x => x.Status == "Pending");
        }

        var tr = await Api.GetAgencyToursAsync();
        if (tr.Success && tr.Data is not null)
        {
            agencyTours = tr.Data;
            capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
            totalSeatEdits = agencyTours.ToDictionary(t => t.Id, t => t.Capacity);
        }

        loading = false;
    }

    private async Task ReloadTours()
    {
        var tr = await Api.GetAgencyToursAsync();
        if (tr.Success && tr.Data is not null)
        {
            agencyTours = tr.Data;
            capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
            totalSeatEdits = agencyTours.ToDictionary(t => t.Id, t => t.Capacity);
        }
        var r = await Api.GetAgencyReservationsAsync();
        if (r.Success && r.Data is not null)
        {
            reservations = r.Data;
            pendingCount = reservations.Count(x => x.Status == "Pending");
        }
    }

    private async Task Approve(int id)
    {
        var res = await Api.SetReservationStatusAsync(id, "Confirmed");
        if (res.Success)
        {
            Toast.ShowSuccess("Reserva aprobada.");
            var list = await Api.GetAgencyReservationsAsync();
            if (list.Success && list.Data is not null) { reservations = list.Data; pendingCount = reservations.Count(x => x.Status == "Pending"); }
        }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }
}
