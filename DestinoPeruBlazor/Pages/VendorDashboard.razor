@page "/vendedor"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Panel Vendedor - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />

    @if (!Auth.IsAuthenticated || Auth.Role != "Vendedor")
    {
        <div class="panel-access-denied alert alert-warning">
            Acceso para vendedores. <a class="btn btn-primary btn-sm ms-2" href="/login">Ingresar</a>
        </div>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando...</p>
    }
    else
    {
        <AgencyBrandHeader Profile="profile" Subtitle="@($"Vendedor: {Auth.Name} — inventario, pagos y manifiesto")" />

        @if (dashboard is not null)
        {
            <div class="metrics-grid metrics-grid-compact">
                <div class="metric-card"><span class="metric-value">@mySales?.Reservations ?? 0</span><span class="metric-label">Mis reservas</span></div>
                <div class="metric-card metric-highlight"><span class="metric-value">S/ @(mySales?.Revenue.ToString("N0") ?? "0")</span><span class="metric-label">Mi recaudado</span></div>
                <div class="metric-card metric-warn"><span class="metric-value">@pendingCount</span><span class="metric-label">Pagos pendientes</span></div>
            </div>
        }

        <div class="panel-tabs">
            <button type="button" class="panel-tab @(tab == "payments" ? "active" : "")" @onclick='() => tab = "payments"'>Pagos</button>
            <button type="button" class="panel-tab @(tab == "manifest" ? "active" : "")" @onclick='() => tab = "manifest"'>Manifiesto</button>
            <button type="button" class="panel-tab @(tab == "inventory" ? "active" : "")" @onclick='() => tab = "inventory"'>Inventario</button>
        </div>

        @if (tab == "payments")
        {
            <section class="dash-panel">
                <h3>Validar Yape / Plin</h3>
                @foreach (var r in reservations.Where(x => x.Status == "Pending"))
                {
                    <div class="reservation-row">
                        <div><strong>@r.TourTitle</strong><br />@r.UserName · S/ @r.Total.ToString("N2")</div>
                        <button class="btn btn-primary btn-sm" @onclick="() => Approve(r.Id)">Verificar y aprobar</button>
                    </div>
                }
                @if (pendingCount == 0) { <p class="text-muted">No hay pagos pendientes.</p> }
            </section>
        }
        else if (tab == "manifest")
        {
            <section class="dash-panel">
                <h3>Manifiesto de pasajeros</h3>
                <p>Vista legal imprimible con DNI y punto de recojo.</p>
                <a class="btn btn-primary" href="/manifiesto" target="_blank">Abrir manifiesto (imprimir / PDF)</a>
            </section>
        }
        else
        {
            <InventoryOpsPanel Tours="agencyTours"
                               PendingReservations="PendingReservations"
                               CapacityEdits="capacityEdits"
                               OnApprove="Approve"
                               OnSaveCapacity="SaveCapacity" />
        }
    }
</div>

@code {
    private AgencyProfileDto? profile;
    private AgencyDashboardDto? dashboard;
    private List<ReservationDto> reservations = [];
    private List<AgencyTourListItemDto> agencyTours = [];
    private Dictionary<int, int> capacityEdits = new();
    private VendorSalesDto? mySales;
    private string tab = "payments";
    private bool loading = true;
    private int pendingCount;
    private List<ReservationDto> PendingReservations => reservations.Where(x => x.Status == "Pending").ToList();

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "Vendedor") { loading = false; return; }

        var pr = await Api.GetAgencyProfileAsync();
        if (pr.Success) profile = pr.Data;

        var d = await Api.GetAgencyDashboardAsync();
        if (d.Success) dashboard = d.Data;
        mySales = dashboard?.VendorSales.FirstOrDefault(v => v.UserId == Auth.UserId);

        var r = await Api.GetAgencyReservationsAsync();
        if (r.Success && r.Data is not null)
        {
            reservations = r.Data;
            pendingCount = reservations.Count(x => x.Status == "Pending");
        }

        var tr = await Api.GetAgencyToursAsync();
        if (tr.Success && tr.Data is not null)
        {
            agencyTours = tr.Data;
            capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
        }

        loading = false;
    }

    private async Task SaveCapacity(int tourId)
    {
        if (!capacityEdits.TryGetValue(tourId, out var cap)) return;
        var res = await Api.UpdateTourCapacityAsync(tourId, cap);
        if (res.Success)
        {
            Toast.ShowSuccess("Cupos actualizados.");
            var tr = await Api.GetAgencyToursAsync();
            if (tr.Success && tr.Data is not null)
            {
                agencyTours = tr.Data;
                capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
            }
        }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }

    private async Task Approve(int id)
    {
        var res = await Api.SetReservationStatusAsync(id, "Confirmed");
        if (res.Success)
        {
            Toast.ShowSuccess("Reserva aprobada.");
            var list = await Api.GetAgencyReservationsAsync();
            if (list.Success && list.Data is not null) { reservations = list.Data; pendingCount = reservations.Count(x => x.Status == "Pending"); }
        }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }
}
