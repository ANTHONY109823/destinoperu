@page "/partner"
@using DestinoPeruBlazor.Services
@inject AuthStateService Auth
@inject ApiService Api
@inject IJSRuntime JS

<PageTitle>Panel Partner - Destino Peru</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />
    @if (!Auth.IsAuthenticated || (Auth.Role != "Agencia" && Auth.Role != "Admin"))
    {
        <div class="alert alert-warning">Acceso para partners (Agencia).</div>
    }
    else
    {
        <h1 class="dashboard-title">Panel Partner</h1>
        <p class="text-muted">Inventario, fotos y manifiesto de pasajeros</p>

        <div class="dashboard-panels">
            <section class="dash-panel">
                <h3>Inventario Pro</h3>
                <p>Gestiona cupos en tiempo real desde la API. Los full-days bloquean sobreventa automaticamente.</p>
            </section>
            <section class="dash-panel">
                <h3>Subir fotos (Drag & Drop)</h3>
                <div class="upload-zone" @ondragover:preventDefault @ondrop="OnDrop">
                    <p>Arrastra una imagen o selecciona archivo</p>
                    <InputFile OnChange="OnFileSelected" accept="image/*" />
                    @if (!string.IsNullOrEmpty(uploadStatus)) { <p class="mt-2 small">@uploadStatus</p> }
                    @if (!string.IsNullOrEmpty(uploadedUrl))
                    {
                        <img src="@uploadedUrl" alt="Preview" class="upload-preview mt-2" />
                    }
                </div>
            </section>
            <section class="dash-panel">
                <h3>Manifiesto de pasajeros</h3>
                <p>Lista de paraderos y DNIs visible en reservas del partner via API <code>/api/reservations/partner/{{id}}</code>.</p>
            </section>
        </div>
    }
</div>

@code {
    private string? uploadStatus;
    private string? uploadedUrl;

    protected override async Task OnInitializedAsync() => await Auth.InitializeAsync();

    private async Task OnFileSelected(InputFileChangeEventArgs e) => await UploadFile(e.File);

    private async Task OnDrop(DragEventArgs _) { /* drop handled via InputFile in WASM limited */ }

    private async Task UploadFile(IBrowserFile? file)
    {
        if (file is null) return;
        uploadStatus = "Subiendo a Cloudinary...";
        await using var stream = file.OpenReadStream(8 * 1024 * 1024);
        var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        var r = await Api.UploadImageAsync(ms, file.Name, "tours");
        if (r.Success) { uploadedUrl = r.Data; uploadStatus = "Listo. URL guardada para tu tour."; }
        else uploadStatus = r.ErrorMessage;
    }
}
