@page "/superadmin/inicio"
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Inicio Super Admin - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page superadmin-page">
    @if (!Auth.IsAuthenticated || Auth.Role != "SuperAdmin")
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🔒" Title="Acceso restringido" Message="Esta sección es solo para el Super Admin.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando resumen global...</p>
    }
    else
    {
        <SuperAdminNav />

        <PageHeader Title="Panel de control global"
                    Subtitle="Métricas y socios · Las agencias publican tours; «Tours» es la categoría del sitio público.">
            <Actions>
                <AppButton Variant="secondary" Icon="📊" OnClick="@(() => Nav.NavigateTo("/superadmin/comparar-tours"))">Comparar tours</AppButton>
            </Actions>
        </PageHeader>

        @if (!string.IsNullOrEmpty(apiWarning))
        {
            <div class="alert alert-warning d-flex flex-wrap gap-2 align-items-center">
                @apiWarning
                <AppButton Variant="secondary" OnClick="LoadAsync">Reintentar</AppButton>
            </div>
        }

        @if (metrics is not null)
        {
            <div class="ds-metrics-grid sa-metrics-6">
                <MetricCard Value="@metrics.TotalUsers.ToString()" Label="Usuarios" Icon="👥" />
                <MetricCard Value="@metrics.TotalPartners.ToString()" Label="Socios totales" Icon="🤝" />
                <MetricCard Value="@metrics.PendingPartners.ToString()" Label="Socios pendientes" Icon="⏳" />
                <MetricCard Value="@metrics.TotalReservations.ToString()" Label="Reservas" Icon="📋" />
                <MetricCard Value="@($"S/ {metrics.TotalRevenue.ToString("N0")}")" Label="Recaudado global" Icon="💰" />
                <MetricCard Value="@($"S/ {metrics.TotalCommissions.ToString("N0")}")" Label="Comisión plataforma (10%)" Icon="🏦" />
            </div>

            <SectionCard Title="Visión general" Subtitle="Actividad de reservas, red de socios y comisión.">
                <div class="sa-charts-row">
                    <div class="sa-chart-card">
                        <MetricDonutChart Percent="@ReservationsPct" CenterValue="@metrics.TotalReservations.ToString()" CenterLabel="Reservas" Title="Actividad reservas" Color="#00695c" />
                    </div>
                    <div class="sa-chart-card">
                        <MetricDonutChart Percent="@PartnersActivePct" CenterValue="@metrics.TotalPartners.ToString()" CenterLabel="Socios" Title="Red de socios" Color="#2e7d32" />
                    </div>
                    <div class="sa-chart-card">
                        <MetricDonutChart Percent="10" CenterValue="@($"S/ {metrics.TotalCommissions:N0}")" CenterLabel="Comisión" Title="Comisión 10%" Color="#B8860B" />
                    </div>
                    <div class="sa-chart-card sa-chart-card-wide">
                        <MetricBarChart Title="Socios por categoría" Items="CategoryBarItems" />
                    </div>
                </div>
            </SectionCard>
        }

        <SectionCard Title="Administración por categoría"
                     Subtitle="Entra a cada rubro para gestionar socios, crear perfiles, suplantar admin, ranking y suspender.">
            <div class="sa-cat-grid">
                @foreach (var cat in SuperAdminCategories.All)
                {
                    var m = dashboard?.Categories.FirstOrDefault(c => c.Key == cat.Key);
                    var isTours = cat.Key == SuperAdminCategories.Tours;
                    <AppCard Class="sa-cat-card">
                        <div class="sa-cat-card-head">
                            <span class="sa-cat-card-icon">@cat.Icon</span>
                            <div class="sa-cat-card-titles">
                                <h3>@cat.Label</h3>
                                @if (isTours)
                                {
                                    <Badge Variant="success">Operativo</Badge>
                                }
                                else
                                {
                                    <Badge Variant="info">Próximamente</Badge>
                                }
                            </div>
                        </div>
                        <p class="sa-cat-card-desc">@cat.Description</p>
                        @if (m is not null)
                        {
                            <div class="sa-cat-card-metrics">
                                <div><strong>@m.Partners</strong><span>socios</span></div>
                                <div><strong>@m.ActiveItems</strong><span>activos</span></div>
                                <div><strong>@m.Reservations</strong><span>reservas</span></div>
                                <div class="sa-cat-rev"><strong>S/ @m.Revenue.ToString("N0")</strong><span>recaudado</span></div>
                            </div>
                        }
                        <div class="sa-cat-card-actions">
                            <AppButton Variant="primary" OnClick="@(() => GoPanel(cat, "partners"))">Administrar</AppButton>
                            <AppButton Variant="secondary" Icon="➕" OnClick="@(() => GoPanel(cat, "create"))">@cat.PartnerNoun</AppButton>
                            <AppButton Variant="ghost" OnClick="@(() => GoPanel(cat, "ranking"))">Ranking</AppButton>
                        </div>
                    </AppCard>
                }
            </div>
        </SectionCard>
    }
</div>

@code {
    private SuperAdminDashboardDto? dashboard;
    private SuperAdminMetricsDto? metrics;
    private List<PartnerListItemDto> partners = [];
    private bool loading = true;
    private string? apiWarning;

    private double ReservationsPct => metrics is null || metrics.TotalTours == 0 ? 0 : Math.Min(100, metrics.TotalReservations * 10.0);
    private double PartnersActivePct => metrics is null || metrics.TotalUsers == 0 ? 0 : Math.Min(100, metrics.TotalPartners * 100.0 / Math.Max(metrics.TotalUsers, 1));

    private List<MetricBarChart.BarItem> CategoryBarItems =>
        dashboard?.Categories.Select(c => new MetricBarChart.BarItem(
            c.Label, c.Icon, c.Partners, c.Partners.ToString(), BarColor(c.Key))).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "SuperAdmin") { loading = false; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        apiWarning = null;
        var d = await Api.GetSuperAdminDashboardAsync();
        if (d.Success && d.Data is not null) { dashboard = d.Data; metrics = d.Data.Global; }
        else
        {
            var m = await Api.GetSuperAdminMetricsAsync();
            if (m.Success) metrics = m.Data;
            else apiWarning = m.ErrorMessage;
        }
        var p = await Api.GetSuperAdminPartnersAsync();
        if (p.Success && p.Data is not null) partners = p.Data;
        loading = false;
    }

    private void GoPanel(SuperAdminCategory cat, string tab) =>
        Nav.NavigateTo($"{cat.Route}?tab={tab}");

    private static string BarColor(string key) => key switch
    {
        "hoteles" => "#1565c0",
        "restaurantes" => "#c62828",
        "cafes-bar" => "#6d4c41",
        _ => "#00695c"
    };
}
