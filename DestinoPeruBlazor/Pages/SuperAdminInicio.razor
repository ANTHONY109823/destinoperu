@page "/superadmin/inicio"
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Inicio Super Admin - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page superadmin-page">
    @if (!Auth.IsAuthenticated || Auth.Role != "SuperAdmin")
    {
        <div class="panel-access-denied alert alert-warning">
            Acceso restringido. <a class="btn btn-primary btn-sm ms-2" href="/login">Ingresar</a>
        </div>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando resumen global...</p>
    }
    else
    {
        <SuperAdminNav />

        <header class="sa-header d-flex flex-wrap justify-content-between align-items-start gap-2">
            <div>
                <h1 class="dashboard-title mb-1">Vista Inicio — Panel de control global</h1>
                <p class="text-muted mb-0">Gráficos consolidados · Cada categoría con su administración Super Admin</p>
            </div>
            <button type="button" class="btn btn-warning btn-sm" disabled="@creatingDemo" @onclick="CreateDemoAgency">
                @(creatingDemo ? "Creando..." : "⚡ Crear agencia demo")
            </button>
        </header>

        @if (lastDemo is not null)
        {
            <div class="alert alert-success">
                <strong>@lastDemo.AgencyName</strong> lista para presentación.<br />
                Admin: <code>@lastDemo.AdminEmail</code> / <code>@lastDemo.AdminPassword</code> · @lastDemo.ToursCreated tours creados.
            </div>
        }

        @if (!string.IsNullOrEmpty(apiWarning))
        {
            <div class="alert alert-warning">@apiWarning <button type="button" class="btn btn-sm btn-outline-primary" @onclick="LoadAsync">Reintentar</button></div>
        }

        @if (metrics is not null)
        {
            <div class="sa-charts-row">
                <div class="sa-chart-card">
                    <MetricDonutChart Percent="@ReservationsPct" CenterValue="@metrics.TotalReservations.ToString()" CenterLabel="Reservas" Title="Actividad reservas" Color="#00695c" />
                </div>
                <div class="sa-chart-card">
                    <MetricDonutChart Percent="@PartnersActivePct" CenterValue="@metrics.TotalPartners.ToString()" CenterLabel="Socios" Title="Red de socios" Color="#2e7d32" />
                </div>
                <div class="sa-chart-card">
                    <MetricDonutChart Percent="10" CenterValue="@($"S/ {metrics.TotalCommissions:N0}")" CenterLabel="Comisión" Title="Comisión 10%" Color="#f9a825" />
                </div>
                <div class="sa-chart-card sa-chart-card-wide">
                    <MetricBarChart Title="Socios por categoría" Items="CategoryBarItems" />
                </div>
            </div>

            <div class="metrics-grid sa-global-metrics">
                <div class="metric-card"><span class="metric-value">@metrics.TotalUsers</span><span class="metric-label">Usuarios</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalPartners</span><span class="metric-label">Socios totales</span></div>
                <div class="metric-card metric-warn"><span class="metric-value">@metrics.PendingPartners</span><span class="metric-label">Pendientes</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalTours</span><span class="metric-label">Publicaciones</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalReservations</span><span class="metric-label">Reservas</span></div>
                <div class="metric-card metric-highlight"><span class="metric-value">S/ @metrics.TotalRevenue.ToString("N0")</span><span class="metric-label">Recaudado global</span></div>
                <div class="metric-card"><span class="metric-value">S/ @metrics.TotalCommissions.ToString("N0")</span><span class="metric-label">Comisiones 10%</span></div>
            </div>
        }

        <h2 class="sa-section-title">Administración por categoría</h2>
        <p class="text-muted small mb-3">Entra al panel de cada rubro: socios, crear perfiles, suplantar admin, ranking y suspender.</p>

        <div class="category-hub-grid">
            @foreach (var cat in SuperAdminCategories.All)
            {
                var m = dashboard?.Categories.FirstOrDefault(c => c.Key == cat.Key);
                var isTours = cat.Key == SuperAdminCategories.Tours;
                <article class="category-hub-card-v2 @(isTours ? "hub-tours-active" : "hub-coming-soon")">
                    <div class="hub-card-head">
                        <span class="category-hub-icon">@cat.Icon</span>
                        <div>
                            <h3>@cat.Label</h3>
                            @if (!isTours)
                            {
                                <span class="hub-badge-soon">Socios listo · operación full próximo</span>
                            }
                            else
                            {
                                <span class="hub-badge-live">Operativo ahora</span>
                            }
                        </div>
                    </div>
                    <p class="category-hub-desc">@cat.Description</p>
                    @if (m is not null)
                    {
                        <div class="hub-mini-metrics">
                            <div class="hub-mini-m"><strong>@m.Partners</strong><span>socios</span></div>
                            <div class="hub-mini-m"><strong>@m.ActiveItems</strong><span>activos</span></div>
                            <div class="hub-mini-m"><strong>@m.Reservations</strong><span>reservas</span></div>
                            <div class="hub-mini-m hub-rev"><strong>S/ @m.Revenue.ToString("N0")</strong></div>
                        </div>
                    }
                    <div class="hub-card-actions">
                        <button type="button" class="btn btn-primary btn-sm" @onclick='() => GoPanel(cat, "partners")'>Administrar</button>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick='() => GoPanel(cat, "create")'>+ Socio</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick='() => GoPanel(cat, "ranking")'>Ranking</button>
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    private SuperAdminDashboardDto? dashboard;
    private SuperAdminMetricsDto? metrics;
    private List<PartnerListItemDto> partners = [];
    private bool loading = true;
    private string? apiWarning;
    private bool creatingDemo;
    private CreateDemoAgencyResponse? lastDemo;

    private double ReservationsPct => metrics is null || metrics.TotalTours == 0 ? 0 : Math.Min(100, metrics.TotalReservations * 10.0);
    private double PartnersActivePct => metrics is null || metrics.TotalUsers == 0 ? 0 : Math.Min(100, metrics.TotalPartners * 100.0 / Math.Max(metrics.TotalUsers, 1));

    private List<MetricBarChart.BarItem> CategoryBarItems =>
        dashboard?.Categories.Select(c => new MetricBarChart.BarItem(
            c.Label, c.Icon, c.Partners, c.Partners.ToString(), BarColor(c.Key))).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "SuperAdmin") { loading = false; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        apiWarning = null;
        var d = await Api.GetSuperAdminDashboardAsync();
        if (d.Success && d.Data is not null) { dashboard = d.Data; metrics = d.Data.Global; }
        else
        {
            var m = await Api.GetSuperAdminMetricsAsync();
            if (m.Success) metrics = m.Data;
            else apiWarning = m.ErrorMessage;
        }
        var p = await Api.GetSuperAdminPartnersAsync();
        if (p.Success && p.Data is not null) partners = p.Data;
        loading = false;
    }

    private void GoPanel(SuperAdminCategory cat, string tab) =>
        Nav.NavigateTo($"{cat.Route}?tab={tab}");

    private async Task CreateDemoAgency()
    {
        creatingDemo = true;
        var r = await Api.CreateSuperAdminDemoAgencyAsync();
        if (r.Success && r.Data is not null)
        {
            lastDemo = r.Data;
            Toast.ShowSuccess("Agencia demo creada.");
            await LoadAsync();
        }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
        creatingDemo = false;
    }

    private static string BarColor(string key) => key switch
    {
        "hoteles" => "#1565c0",
        "restaurantes" => "#c62828",
        "cafes-bar" => "#6d4c41",
        _ => "#00695c"
    };
}
