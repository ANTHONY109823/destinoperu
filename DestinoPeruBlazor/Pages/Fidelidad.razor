@page "/fidelidad"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Puntos de fidelidad - DestinoPerú</PageTitle>

<div class="container py-4">
    <BackToHome />
    @if (!Auth.IsAuthenticated || Auth.Role != "Cliente")
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="⭐" Title="Inicia sesión" Message="Ingresa como cliente para ver tus puntos de fidelidad.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando...</p>
    }
    else if (loyalty is not null)
    {
        <PageHeader Title="Mis puntos DestinoPerú" Subtitle="Ganas ~1% del monto de cada reserva confirmada. Canje próximamente." />
        <div class="ds-metrics-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">
            <MetricCard Value="@loyalty.Points.ToString()" Label="Puntos disponibles" Icon="⭐" />
            <MetricCard Value="@loyalty.LifetimePoints.ToString()" Label="Acumulados históricos" Icon="🏅" />
        </div>
        <div class="mt-3">
            <AppButton Variant="primary" Icon="🗺️" OnClick="@(() => Nav.NavigateTo("/"))">Reservar más tours</AppButton>
        </div>
    }
</div>

@code {
    private LoyaltyDto? loyalty;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role == "Cliente")
        {
            var r = await Api.GetLoyaltyAsync();
            if (r.Success) loyalty = r.Data;
        }
        loading = false;
    }
}
