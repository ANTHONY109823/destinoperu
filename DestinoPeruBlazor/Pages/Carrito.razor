@page "/carrito"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject CartService Cart
@inject AuthStateService Auth
@inject ApiService Api
@inject NavigationManager Nav
@inject ToastService Toast
@implements IDisposable

<PageTitle>Carrito - DestinoPerú</PageTitle>

<div class="container py-4">
    <BackToHome />
    <PageHeader Title="Carrito multidestino" Subtitle="Reserva varios tours de distintos departamentos en un solo flujo." />

    @if (Cart.Items.Count == 0)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🛒" Title="Tu carrito está vacío" Message="Explora experiencias y agrégalas para reservarlas juntas.">
            <Action><AppButton Variant="primary" Icon="🔍" OnClick="@(() => Nav.NavigateTo("/"))">Buscar tours</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else
    {
        <SectionCard Title="@($"Tus experiencias ({Cart.Items.Count})")">
            @foreach (var item in Cart.Items)
            {
                <div class="cart-row">
                    <div>
                        <strong>@item.Title</strong>
                        <p class="mb-0 text-muted small">@item.Department · @item.Quantity pax · S/ @((item.Price * item.Quantity).ToString("N2"))</p>
                    </div>
                    <div class="cart-row-actions">
                        <AppButton Variant="secondary" OnClick="@(() => Nav.NavigateTo($"/tour/{item.Slug}"))">Ver</AppButton>
                        <AppButton Variant="ghost" Icon="🗑️" OnClick="@(() => Remove(item.TourId))">Quitar</AppButton>
                    </div>
                </div>
            }
            <div class="cart-total-row">
                <span>Total estimado</span>
                <strong>S/ @total.ToString("N2")</strong>
            </div>

            @if (!Auth.IsAuthenticated)
            {
                <AppButton Variant="primary" Block="true" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar para reservar</AppButton>
            }
            else if (Auth.Role != "Cliente")
            {
                <div class="alert alert-warning mb-0">El carrito es para clientes. Usa el panel de agencia para operaciones.</div>
            }
            else
            {
                <AppButton Variant="primary" Block="true" Loading="checkingOut" OnClick="CheckoutAll">Reservar todos</AppButton>
            }
        </SectionCard>
    }
</div>

@code {
    private decimal total => Cart.Items.Sum(i => i.Price * i.Quantity);
    private bool checkingOut;

    protected override async Task OnInitializedAsync()
    {
        await Cart.InitializeAsync();
        Cart.OnChange += StateHasChanged;
    }

    private async Task Remove(int tourId)
    {
        await Cart.RemoveAsync(tourId);
        StateHasChanged();
    }

    private async Task CheckoutAll()
    {
        checkingOut = true;
        foreach (var item in Cart.Items.ToList())
        {
            var r = await Api.CreateReservationAsync(new CreateReservationRequest { TourId = item.TourId, Quantity = item.Quantity });
            if (!r.Success)
            {
                Toast.ShowError(r.ErrorMessage ?? $"Error en {item.Title}");
                checkingOut = false;
                return;
            }
        }
        await Cart.ClearAsync();
        Toast.ShowSuccess("Reservas creadas. Completa el pago en Mis reservas.");
        Nav.NavigateTo("/mis-reservas");
        checkingOut = false;
    }

    public void Dispose() => Cart.OnChange -= StateHasChanged;
}
