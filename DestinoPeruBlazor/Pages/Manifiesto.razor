@page "/manifiesto"
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>Manifiesto legal - DestinoPerú</PageTitle>

<div class="container py-4 @(printMode ? "manifest-print" : "")">
    @if (!Auth.IsAuthenticated || Auth.Role is not ("Admin" or "Vendedor" or "SuperAdmin"))
    {
        <div class="alert alert-warning">Acceso restringido al personal de agencia.</div>
    }
    else if (loading)
    {
        <p class="text-muted">Generando manifiesto...</p>
    }
    else if (manifest is null)
    {
        <div class="alert alert-info">No hay pasajeros confirmados para el manifiesto.</div>
    }
    else
    {
        <div class="manifest-actions no-print">
            <a class="btn btn-outline-secondary btn-sm" href="@backUrl">← Volver al panel</a>
            <div class="manifest-download-group">
                <button type="button" class="btn btn-primary btn-sm" @onclick="DownloadCsv">
                    ⬇ Descargar CSV (Excel)
                </button>
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="Print">
                    ⬇ Guardar PDF
                </button>
            </div>
        </div>
        <p class="small text-muted no-print mb-3">
            CSV abre en Excel con DNI y punto de recojo. PDF usa «Guardar como PDF» en el diálogo de impresión.
        </p>

        <header class="manifest-header text-center mb-4">
            <h1 class="h4 mb-1">MANIFIESTO DE PASAJEROS</h1>
            <p class="mb-0"><strong>@manifest.AgencyName</strong></p>
            <p class="mb-0">Tour: @manifest.TourTitle</p>
            <p class="mb-0">Fecha salida: @manifest.TourDate.ToString("dd/MM/yyyy HH:mm")</p>
            <p class="small text-muted">Documento generado @DateTime.Now.ToString("dd/MM/yyyy HH:mm") — DestinoPerú</p>
        </header>

        <table class="table table-bordered manifest-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre completo</th>
                    <th>DNI</th>
                    <th>Punto recojo</th>
                    <th class="no-print-col">Cant.</th>
                </tr>
            </thead>
            <tbody>
                @{ var n = 0; }
                @foreach (var p in manifest.Passengers)
                {
                    n++;
                    <tr>
                        <td>@n</td>
                        <td>@p.FullName</td>
                        <td>@p.Dni</td>
                        <td>@p.PickupPoint</td>
                        <td class="no-print-col">@p.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>

        <footer class="manifest-footer mt-5">
            <div class="row">
                <div class="col-6">
                    <p>Responsable operaciones: _________________________</p>
                </div>
                <div class="col-6 text-end">
                    <p>Firma guía / conductor: _________________________</p>
                </div>
            </div>
            <p class="small text-muted text-center">Registro interno de pasajeros — operadores en DestinoPerú.</p>
        </footer>
    }
</div>

@code {
    private ManifestDto? manifest;
    private bool loading = true;
    private bool printMode;
    private string backUrl = "/vendedor";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        backUrl = Auth.Role switch
        {
            "Admin" => "/admin",
            "SuperAdmin" => "/superadmin/inicio",
            _ => "/vendedor"
        };
        if (Auth.IsAuthenticated && Auth.Role is "Admin" or "Vendedor" or "SuperAdmin")
        {
            var r = await Api.GetManifestAsync();
            if (r.Success) manifest = r.Data;
        }
        loading = false;
    }

    private async Task DownloadCsv()
    {
        if (manifest is null) return;
        var rows = new List<string[]>();
        var i = 0;
        foreach (var p in manifest.Passengers)
        {
            i++;
            rows.Add([i.ToString(), p.FullName, p.Dni, p.PickupPoint, p.Quantity.ToString()]);
        }
        var meta = $"Agencia,{CsvExportHelper.Escape(manifest.AgencyName)}\n" +
                   $"Tour,{CsvExportHelper.Escape(manifest.TourTitle)}\n" +
                   $"Fecha salida,{manifest.TourDate:dd/MM/yyyy HH:mm}\n" +
                   $"Generado,{DateTime.Now:dd/MM/yyyy HH:mm}\n\n";
        var body = CsvExportHelper.ToCsv(rows, "#,Nombre completo,DNI,Punto recojo,Cantidad");
        var file = $"manifiesto-{CsvExportHelper.SafeFileName(manifest.TourTitle)}-{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("destinoPeruDownload.csv", file, meta + body);
        Toast.ShowSuccess("Manifiesto descargado (CSV).");
    }

    private async Task Print()
    {
        printMode = true;
        StateHasChanged();
        await Task.Delay(150);
        await JS.InvokeVoidAsync("destinoPeruDownload.printPage");
        printMode = false;
        StateHasChanged();
        Toast.ShowSuccess("Elige «Guardar como PDF» en el diálogo de impresión.");
    }
}
