@page "/login"
@page "/register"
@using System.ComponentModel.DataAnnotations
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>@(IsRegister ? "Registro" : "Ingresar") - DestinoPerú</PageTitle>

<div class="container auth-container">
    <BackToHome />

    <div class="auth-card">
        <h2>@(IsRegister ? "Crear cuenta" : "Iniciar sesión")</h2>

        <div class="auth-tabs">
            <NavLink class="auth-tab-link" href="/login" Match="NavLinkMatch.Prefix">Ingresar</NavLink>
            <NavLink class="auth-tab-link" href="/register">Crear cuenta viajero</NavLink>
        </div>
        @if (!IsRegister)
        {
            <p class="auth-hint small text-muted">Agencias, vendedores y administradores: usa tus credenciales en esta pantalla.</p>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-danger">@message</div>
        }

        @if (Auth.IsAuthenticated && !IsRegister)
        {
            <div class="alert alert-success">
                Sesión activa como <strong>@Auth.Name</strong> (@Auth.Role).
            </div>
            <button class="btn btn-outline-danger" @onclick="Logout">Cerrar sesión</button>
        }
        else if (IsRegister)
        {
            <EditForm Model="registerForm" OnValidSubmit="DoRegister">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger small" />
                <div class="mb-3">
                    <label class="form-label">Nombre completo</label>
                    <InputText class="form-control" @bind-Value="registerForm.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <InputText type="email" class="form-control" @bind-Value="registerForm.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña (mín. 6 caracteres)</label>
                    <InputText type="password" class="form-control" @bind-Value="registerForm.Password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirmar contraseña</label>
                    <InputText type="password" class="form-control" @bind-Value="registerForm.ConfirmPassword" />
                </div>
                <button type="submit" class="btn btn-primary w-100" disabled="@loading">@(loading ? "Registrando..." : "Crear cuenta")</button>
            </EditForm>
        }
        else
        {
            <EditForm Model="loginModel" OnValidSubmit="DoLogin">
                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <InputText type="email" class="form-control" @bind-Value="loginModel.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <InputText type="password" class="form-control" @bind-Value="loginModel.Password" />
                </div>
                <button type="submit" class="btn btn-primary w-100" disabled="@loading">@(loading ? "Ingresando..." : "Ingresar")</button>
            </EditForm>
        }
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private RegisterFormModel registerForm = new();
    private bool loading;
    private string? message;
    private string? successMessage;

    private bool IsRegister => Nav.ToBaseRelativePath(Nav.Uri).StartsWith("register", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Nav.Uri.Contains("registered=1", StringComparison.OrdinalIgnoreCase))
            successMessage = "Registro exitoso. Ya puedes iniciar sesión.";
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Email) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            message = "Ingresa correo y contraseña.";
            return;
        }

        loading = true;
        message = null;
        var result = await Api.LoginAsync(loginModel);
        if (result.Success && result.Data is not null)
        {
            await Auth.SetAuthAsync(result.Data);
            Nav.NavigateTo(RedirectForRole(result.Data.Role));
        }
        else
            message = result.ErrorMessage;
        loading = false;
    }

    private async Task DoRegister()
    {
        if (registerForm.Password != registerForm.ConfirmPassword)
        {
            message = "Las contraseñas no coinciden.";
            return;
        }
        if (registerForm.Password.Length < 6)
        {
            message = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        loading = true;
        message = null;
        successMessage = null;

        var result = await Api.RegisterAsync(new RegisterRequest
        {
            Name = registerForm.Name.Trim(),
            Email = registerForm.Email.Trim().ToLowerInvariant(),
            Password = registerForm.Password,
            Role = "Cliente"
        });

        if (result.Success && result.Data is not null)
        {
            await Auth.SetAuthAsync(result.Data);
            Nav.NavigateTo("/");
        }
        else
            message = result.ErrorMessage ?? "No se pudo completar el registro.";
        loading = false;
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        message = null;
        successMessage = null;
    }

    private static string RedirectForRole(string role) => role switch
    {
        "SuperAdmin" => "/superadmin",
        "Admin" => "/admin",
        "Vendedor" => "/vendedor",
        "Agencia" => "/partner",
        _ => "/"
    };

    private class RegisterFormModel
    {
        [Required(ErrorMessage = "El nombre es obligatorio.")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Ingresa un email válido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        [MinLength(6, ErrorMessage = "Mínimo 6 caracteres.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirma tu contraseña.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
