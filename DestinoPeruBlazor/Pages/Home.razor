@page "/"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components
@inject ApiService Api

<PageTitle>Destino Peru - Tours</PageTitle>

<section class="hero">
    <div class="hero-content container">
        <span class="hero-badge">Destino Peru</span>
        <h1>Descubre el Peru</h1>
        <p>Tours, experiencias y aventuras con agencias verificadas.</p>
    </div>
</section>

<section class="filters container">
    <div class="filters-grid">
        <input class="form-control" placeholder="Destino (Cusco, Lima...)" @bind="location" />
        <input type="date" class="form-control" @bind="fromDate" />
        <input type="number" class="form-control" placeholder="Precio max (S/)" @bind="maxPrice" />
        <button class="btn btn-primary w-100" @onclick="Search" disabled="@loading">Buscar</button>
    </div>
</section>

<section class="container tours-section">
    @if (loading)
    {
        <div class="tours-grid" aria-busy="true" aria-label="Cargando tours">
            @for (var i = 0; i < 6; i++)
            {
                <TourCardSkeleton />
            }
        </div>
    }
    else if (!loadSuccess)
    {
        <EmptyState Icon="⚠️" Title="No pudimos cargar los tours"
                    Message="Revisa tu conexion o intenta de nuevo en unos segundos.">
            <button class="btn btn-primary" @onclick="Search">Reintentar</button>
        </EmptyState>
    }
    else if (tours.Count == 0)
    {
        <EmptyState Icon="🏔️" Title="No hay visitas disponibles"
                    Message="No encontramos tours con esos filtros. Prueba otra ciudad, fecha o amplia el precio maximo.">
            <button class="btn btn-outline-primary" @onclick="ClearFilters">Ver todos los tours</button>
        </EmptyState>
    }
    else
    {
        <p class="tours-count">@tours.Count tour@(tours.Count == 1 ? "" : "s") disponible@(tours.Count == 1 ? "" : "s")</p>
        <div class="tours-grid">
            @foreach (var tour in tours)
            {
                <TourCard Tour="tour" />
            }
        </div>
    }
</section>

@code {
    private List<TourDto> tours = [];
    private string? location;
    private DateTime? fromDate;
    private decimal? maxPrice;
    private bool loading = true;
    private bool loadSuccess = true;

    protected override async Task OnInitializedAsync() => await LoadTours();

    private async Task Search() => await LoadTours();

    private async Task ClearFilters()
    {
        location = null;
        fromDate = null;
        maxPrice = null;
        await LoadTours();
    }

    private async Task LoadTours()
    {
        loading = true;
        loadSuccess = true;
        StateHasChanged();

        var result = await Api.GetToursAsync(location, fromDate, maxPrice);
        if (result.Success && result.Data is not null)
            tours = result.Data;
        else
        {
            tours = [];
            loadSuccess = false;
        }

        loading = false;
    }
}
