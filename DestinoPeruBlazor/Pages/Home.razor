@page "/"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components
@inject ApiService Api

<PageTitle>DestinoPerú — Tours y experiencias en Perú</PageTitle>

<section class="home-hero" style="background-image: url('https://images.unsplash.com/photo-1587595431973-160d0d94add1?w=1600&q=80');">
    <div class="home-hero-overlay"></div>
    <div class="container home-hero-stack">
        <div class="home-hero-head">
            <h1>Descubre el Perú con agencias verificadas</h1>
            <p class="home-hero-sub">Reserva full days, paquetes y experiencias únicas. Paga con Yape o Plin.</p>
        </div>

        <div class="home-search-card home-search-linear">
            <div class="home-search-linear-grid @GridClass">
                <div class="hs-field">
                    <label>Departamento</label>
                    <select class="form-select" @bind="department">
                        <option value="">Todos</option>
                        @foreach (var d in PeruDepartments) { <option value="@d">@d</option> }
                    </select>
                </div>
                <div class="hs-field">
                    <label>Ciudad</label>
                    <input class="form-control" placeholder="Cusco, Lima..." @bind="location" />
                </div>
                <div class="hs-field">
                    <label>Experiencia</label>
                    <select class="form-select" @bind="adventureType" @bind:after="OnExperienceChanged">
                        <option value="">Todas</option>
                        <option value="FullDay">Full Days</option>
                        <option value="Paquete2D1N">Paquetes completos 2D/1N</option>
                        <option value="Cultural">Cultural</option>
                        <option value="CafeBar">Café / Bar</option>
                    </select>
                </div>
                <div class="hs-field">
                    <label>@(IsPackage ? "Fecha ida" : "Fecha")</label>
                    <input type="date" class="form-control" @bind="fromDate" />
                </div>
                @if (IsPackage)
                {
                    <div class="hs-field">
                        <label>Fecha retorno</label>
                        <input type="date" class="form-control" @bind="toDate" min="@MinReturnDate" />
                    </div>
                }
                <div class="hs-field hs-field-btn">
                    <label>&nbsp;</label>
                    <button type="button" class="btn btn-primary btn-search-linear" @onclick="Search" disabled="@loading">Buscar</button>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container home-destinos">
    <h2 class="section-title">Destinos populares</h2>
    <div class="destinos-grid">
        @foreach (var d in PopularDestinations)
        {
            <button type="button" class="destino-card" @onclick="() => FilterByDepartment(d.Name)">
                <div class="destino-img" style="background-image: url('@d.Image')"></div>
                <span class="destino-name">@d.Name</span>
            </button>
        }
    </div>
</section>

<section class="container tours-section">
    <h2 class="section-title">Experiencias disponibles</h2>
    @if (loading)
    {
        <div class="tours-grid" aria-busy="true">
            @for (var i = 0; i < 6; i++) { <TourCardSkeleton /> }
        </div>
    }
    else if (!loadSuccess)
    {
        <EmptyState Icon="⚠️" Title="No pudimos cargar los tours" Message="Revisa tu conexión o intenta de nuevo.">
            <button class="btn btn-primary" @onclick="Search">Reintentar</button>
        </EmptyState>
    }
    else if (tours.Count == 0)
    {
        <EmptyState Icon="🏔️" Title="Sin resultados" Message="Prueba otros filtros o departamento.">
            <button class="btn btn-outline-primary" @onclick="ClearFilters">Ver todos</button>
        </EmptyState>
    }
    else
    {
        <p class="tours-count">@totalCount experiencia@(totalCount == 1 ? "" : "s") · página @currentPage de @totalPages</p>
        <div class="tours-grid">
            @foreach (var tour in tours) { <TourCard Tour="tour" /> }
        </div>
        @if (totalPages > 1)
        {
            <div class="pagination-bar">
                <button class="btn btn-outline-primary btn-sm" disabled="@(currentPage <= 1)" @onclick="PrevPage">Anterior</button>
                <span>Página @currentPage de @totalPages</span>
                <button class="btn btn-outline-primary btn-sm" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Siguiente</button>
            </div>
        }
    }
</section>

<section class="home-trust-strip">
    <div class="container trust-strip">
        <div class="trust-strip-item"><span class="trust-strip-icon">📱</span><div><strong>Yape y Plin</strong><span>Pago seguro.</span></div></div>
        <div class="trust-strip-item"><span class="trust-strip-icon">✓</span><div><strong>Agencias verificadas</strong><span>Partners revisados.</span></div></div>
        <div class="trust-strip-item"><span class="trust-strip-icon">💬</span><div><strong>Soporte cercano</strong><span>En español.</span></div></div>
    </div>
</section>

<section class="home-cta">
    <div class="container">
        <div class="home-cta-box">
            <h2>¿Listo para tu próxima aventura?</h2>
            <p>Explora tours en todo el Perú o solicita unir tu agencia a DestinoPerú.</p>
            <div class="home-cta-btns">
                <a class="btn-cta btn-cta-main" href="/">Ver tours disponibles</a>
                <a class="btn-cta btn-cta-alt" href="/solicitud-agencia">Solicitar unir mi agencia</a>
            </div>
        </div>
    </div>
</section>

@code {
    private List<TourDto> tours = [];
    private string? department;
    private string? location;
    private string? adventureType;
    private DateTime? fromDate;
    private DateTime? toDate;
    private int currentPage = 1;
    private int totalCount;
    private int totalPages = 1;
    private bool loading = true;
    private bool loadSuccess = true;

    private bool IsPackage => adventureType == "Paquete2D1N";
    private string GridClass => IsPackage ? "has-return" : "";
    private string? MinReturnDate => fromDate?.ToString("yyyy-MM-dd");

    private static readonly string[] PeruDepartments =
    [
        "Amazonas", "Áncash", "Apurímac", "Arequipa", "Ayacucho", "Cajamarca", "Callao",
        "Cusco", "Huancavelica", "Huánuco", "Ica", "Junín", "La Libertad", "Lambayeque",
        "Lima", "Loreto", "Madre de Dios", "Moquegua", "Pasco", "Piura", "Puno",
        "San Martín", "Tacna", "Tumbes", "Ucayali"
    ];

    private static readonly (string Name, string Image)[] PopularDestinations =
    [
        ("Cusco", "https://images.unsplash.com/photo-1526392060635-9d601b837dd0?w=600&q=80"),
        ("Ica", "https://images.unsplash.com/photo-1587595431973-160d0d94add1?w=600&q=80"),
        ("Arequipa", "https://images.unsplash.com/photo-1516026679272-898a54700f3f?w=600&q=80"),
        ("Lima", "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=600&q=80"),
        ("Puno", "https://images.unsplash.com/photo-1476514525535-07fb3b4eae35?w=600&q=80")
    ];

    protected override async Task OnInitializedAsync() => await LoadTours();

    private void OnExperienceChanged()
    {
        if (!IsPackage) toDate = null;
        else if (fromDate.HasValue && (!toDate.HasValue || toDate < fromDate))
            toDate = fromDate.Value.AddDays(1);
    }

    private async Task FilterByDepartment(string dept) { department = dept; currentPage = 1; await LoadTours(); }
    private async Task Search() { currentPage = 1; await LoadTours(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadTours(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadTours(); } }

    private async Task ClearFilters()
    {
        department = location = adventureType = null;
        fromDate = toDate = null; currentPage = 1;
        await LoadTours();
    }

    private async Task LoadTours()
    {
        loading = true; loadSuccess = true;
        StateHasChanged();
        var result = await Api.SearchToursAsync(department, location, adventureType, fromDate, toDate, currentPage);
        if (result.Success && result.Data is not null)
        {
            tours = result.Data.Items;
            totalCount = result.Data.TotalCount;
            totalPages = Math.Max(1, result.Data.TotalPages);
        }
        else { tours = []; loadSuccess = false; }
        loading = false;
    }
}
