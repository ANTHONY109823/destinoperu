@page "/"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api

<PageTitle>DestinoPerú — Tours y experiencias en Perú</PageTitle>

<section class="home-hero" style="background-image: url('https://images.unsplash.com/photo-1526392060635-9d601b837dd0?w=1600&q=80');">
    <div class="home-hero-overlay"></div>
    <div class="container home-hero-stack">
        <div class="home-hero-head">
            <h1 class="home-hero-title" tabindex="-1">Descubre el Perú con agencias verificadas</h1>
            <p class="home-hero-sub">Reserva full days, paquetes y experiencias únicas con operadores locales. Paga seguro con Yape o Plin.</p>
        </div>

        <div class="home-hero-metrics">
            <div class="home-hero-metric">
                <span class="home-hero-metric-value">@(loading ? "…" : $"{totalCount}+")</span>
                <span class="home-hero-metric-label">Experiencias disponibles</span>
            </div>
            <div class="home-hero-metric">
                <span class="home-hero-metric-value">@(loading ? "…" : $"{AgencyCount}")</span>
                <span class="home-hero-metric-label">Agencias verificadas</span>
            </div>
            <div class="home-hero-metric">
                <span class="home-hero-metric-value">Yape · Plin</span>
                <span class="home-hero-metric-label">Pago 100% seguro</span>
            </div>
        </div>

        <div class="home-search-card">
            <div class="home-search-grid @GridClass">
                <FormField Label="Departamento" Type="select" @bind-Value="department">
                    <option value="">Todos</option>
                    @foreach (var d in PeruDepartments) { <option value="@d">@d</option> }
                </FormField>
                <FormField Label="Ciudad / destino" Placeholder="Cusco, Lima..." @bind-Value="location" />
                <FormField Label="Experiencia" Type="select" @bind-Value="adventureType" @bind-Value:after="OnExperienceChanged">
                    <option value="">Todas</option>
                    <option value="FullDay">Full Days</option>
                    <option value="Paquete2D1N">Paquetes 2D/1N</option>
                    <option value="Cultural">Cultural</option>
                    <option value="Trekking">Trekking</option>
                    <option value="Aventura">Aventura</option>
                </FormField>
                <FormField Label="@(IsPackage ? "Fecha ida" : "Fecha")" Type="date" @bind-Value="fromDateStr" />
                @if (IsPackage)
                {
                    <FormField Label="Fecha retorno" Type="date" @bind-Value="toDateStr" />
                }
                <FormField Label="Precio máx. (S/)" Type="number" Placeholder="Sin límite" @bind-Value="maxPriceStr" />
                <div class="home-search-btn">
                    <AppButton Variant="primary" Block="true" Icon="🔍" Loading="loading" OnClick="Search">Buscar experiencias</AppButton>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container home-destinos">
    <h2 class="section-title">Destinos populares</h2>
    <div class="destinos-grid">
        @foreach (var d in PopularDestinations)
        {
            <button type="button" class="destino-card @(department == d.Name ? "active" : "")" @onclick="() => FilterByDepartment(d.Name)">
                <div class="destino-img" style="background-image: url('@d.Image')"></div>
                <span class="destino-name">@d.Name</span>
            </button>
        }
    </div>
</section>

<section class="container tours-section">
    <div class="tours-section-head">
        <h2 class="section-title mb-0">Experiencias disponibles</h2>
        @if (!loading && loadSuccess && tours.Count > 0)
        {
            <span class="tours-count">@totalCount experiencia@(totalCount == 1 ? "" : "s") · página @currentPage de @totalPages</span>
        }
    </div>

    @if (loading)
    {
        <div class="tours-grid" aria-busy="true">
            @for (var i = 0; i < 6; i++) { <TourCardSkeleton /> }
        </div>
    }
    else if (!loadSuccess)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="⚠️" Title="No pudimos cargar los tours" Message="Revisa tu conexión o intenta de nuevo.">
            <Action><AppButton Variant="primary" OnClick="Search">Reintentar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (tours.Count == 0)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🏔️" Title="Sin resultados" Message="Prueba otros filtros o cambia de departamento.">
            <Action><AppButton Variant="secondary" OnClick="ClearFilters">Ver todos los tours</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else
    {
        <div class="tours-grid">
            @foreach (var tour in tours) { <TourCard Tour="tour" /> }
        </div>
        @if (totalPages > 1)
        {
            <div class="pagination-bar">
                <AppButton Variant="secondary" Disabled="@(currentPage <= 1)" OnClick="PrevPage">Anterior</AppButton>
                <span>Página @currentPage de @totalPages</span>
                <AppButton Variant="secondary" Disabled="@(currentPage >= totalPages)" OnClick="NextPage">Siguiente</AppButton>
            </div>
        }
    }
</section>

<section class="home-trust-strip">
    <div class="container trust-strip">
        <div class="trust-strip-item"><span class="trust-strip-icon">📱</span><div><strong>Pago seguro Yape / Plin</strong><span>Confirmación inmediata.</span></div></div>
        <div class="trust-strip-item"><span class="trust-strip-icon">✓</span><div><strong>Agencias verificadas</strong><span>Operadores revisados.</span></div></div>
        <div class="trust-strip-item"><span class="trust-strip-icon">💬</span><div><strong>Soporte cercano</strong><span>Atención en español.</span></div></div>
    </div>
</section>

<section class="home-cta">
    <div class="container">
        <div class="home-cta-box">
            <h2>¿Listo para tu próxima aventura?</h2>
            <p>Explora tours en todo el Perú o solicita unir tu agencia a DestinoPerú.</p>
            <div class="home-cta-btns">
                <a class="btn-cta btn-cta-main" href="/">Ver tours disponibles</a>
                <a class="btn-cta btn-cta-alt" href="/solicitud-agencia">Solicitar unir mi agencia</a>
            </div>
        </div>
    </div>
</section>

@code {
    private List<TourDto> tours = [];
    private string? department;
    private string? location;
    private string? adventureType;
    private string? fromDateStr;
    private string? toDateStr;
    private string? maxPriceStr;
    private int currentPage = 1;
    private int totalCount;
    private int totalPages = 1;
    private bool loading = true;
    private bool loadSuccess = true;

    private bool IsPackage => adventureType == "Paquete2D1N";
    private string GridClass => IsPackage ? "has-return" : "";

    private int AgencyCount => tours.Select(t => t.PartnerName)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Distinct(StringComparer.OrdinalIgnoreCase).Count();

    private static readonly string[] PeruDepartments =
    [
        "Amazonas", "Áncash", "Apurímac", "Arequipa", "Ayacucho", "Cajamarca", "Callao",
        "Cusco", "Huancavelica", "Huánuco", "Ica", "Junín", "La Libertad", "Lambayeque",
        "Lima", "Loreto", "Madre de Dios", "Moquegua", "Pasco", "Piura", "Puno",
        "San Martín", "Tacna", "Tumbes", "Ucayali"
    ];

    private static readonly (string Name, string Image)[] PopularDestinations =
    [
        ("Cusco", "https://images.unsplash.com/photo-1526392060635-9d601b837dd0?w=600&q=80"),
        ("Ica", "https://images.unsplash.com/photo-1587595431973-160d0d94add1?w=600&q=80"),
        ("Arequipa", "https://images.unsplash.com/photo-1516026679272-898a54700f3f?w=600&q=80"),
        ("Lima", "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=600&q=80"),
        ("Puno", "https://images.unsplash.com/photo-1476514525535-07fb3b4eae35?w=600&q=80")
    ];

    [Parameter, SupplyParameterFromQuery(Name = "dept")] public string? QueryDept { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "type")] public string? QueryType { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "q")] public string? QueryLocation { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(QueryDept)) department = QueryDept;
        if (!string.IsNullOrWhiteSpace(QueryType)) adventureType = QueryType;
        if (!string.IsNullOrWhiteSpace(QueryLocation)) location = QueryLocation;
        await LoadTours();
    }

    private void OnExperienceChanged()
    {
        if (!IsPackage) toDateStr = null;
    }

    private async Task FilterByDepartment(string dept)
    {
        department = department == dept ? null : dept;
        currentPage = 1;
        await LoadTours();
    }

    private async Task Search() { currentPage = 1; await LoadTours(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadTours(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadTours(); } }

    private async Task ClearFilters()
    {
        department = location = adventureType = null;
        fromDateStr = toDateStr = maxPriceStr = null;
        currentPage = 1;
        await LoadTours();
    }

    private async Task LoadTours()
    {
        loading = true; loadSuccess = true;
        StateHasChanged();

        DateTime? fromDate = DateTime.TryParse(fromDateStr, out var f) ? f : null;
        DateTime? toDate = DateTime.TryParse(toDateStr, out var t) ? t : null;
        decimal? maxPrice = decimal.TryParse(maxPriceStr, out var p) && p > 0 ? p : null;

        var result = await Api.SearchToursAsync(department, location, adventureType, fromDate, toDate, currentPage, maxPrice);
        if (result.Success && result.Data is not null)
        {
            tours = result.Data.Items;
            totalCount = result.Data.TotalCount;
            totalPages = Math.Max(1, result.Data.TotalPages);
        }
        else { tours = []; loadSuccess = false; }
        loading = false;
    }
}
