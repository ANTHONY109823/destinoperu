@page "/superadmin"
@page "/superadmin/inicio"
@page "/superadmin/tours"
@page "/superadmin/hoteles"
@page "/superadmin/restaurantes"
@page "/superadmin/cafes-bar"
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>@(IsInicio ? "Inicio Super Admin" : $"Super Admin — {ActiveCategory?.Label}") - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page superadmin-page">
    @if (!Auth.IsAuthenticated || Auth.Role != "SuperAdmin")
    {
        <div class="panel-access-denied alert alert-warning">
            Acceso restringido. Inicia sesión como Super Admin.
            <a class="btn btn-primary btn-sm ms-2" href="/login">Ingresar</a>
        </div>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando tablero maestro...</p>
    }
    else
    {
        <SuperAdminNav />

        @if (!string.IsNullOrEmpty(apiWarning))
        {
            <div class="alert alert-warning mt-3">@apiWarning
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="LoadData">Reintentar</button>
            </div>
        }

        @if (IsInicio)
        {
            <header class="sa-header">
                <h1 class="dashboard-title mb-1">Vista Inicio — Control total</h1>
                <p class="text-muted mb-0">Resumen de todas las categorías · Comisión 10% · Suplantación y socios</p>
            </header>

            @if (metrics is not null)
            {
                <div class="metrics-grid sa-global-metrics">
                    <div class="metric-card"><span class="metric-value">@metrics.TotalUsers</span><span class="metric-label">Usuarios</span></div>
                    <div class="metric-card"><span class="metric-value">@metrics.TotalPartners</span><span class="metric-label">Socios totales</span></div>
                    <div class="metric-card metric-warn"><span class="metric-value">@metrics.PendingPartners</span><span class="metric-label">Pendientes</span></div>
                    <div class="metric-card"><span class="metric-value">@metrics.TotalTours</span><span class="metric-label">Publicaciones</span></div>
                    <div class="metric-card"><span class="metric-value">@metrics.TotalReservations</span><span class="metric-label">Reservas</span></div>
                    <div class="metric-card metric-highlight"><span class="metric-value">S/ @metrics.TotalRevenue.ToString("N0")</span><span class="metric-label">Recaudado global</span></div>
                    <div class="metric-card"><span class="metric-value">S/ @metrics.TotalCommissions.ToString("N0")</span><span class="metric-label">Comisiones 10%</span></div>
                </div>
            }

            <h2 class="sa-section-title">Paneles por categoría</h2>
            <p class="text-muted small">Entra a cada rubro para gestionar socios, crear perfiles, suplantar admins y ver ranking.</p>

            <div class="category-hub-grid">
                @foreach (var cat in SuperAdminCategories.All)
                {
                    var m = GetCategoryMetrics(cat.Key);
                    <a class="category-hub-card" href="@cat.Route">
                        <span class="category-hub-icon">@cat.Icon</span>
                        <h3>@cat.Label</h3>
                        <p class="category-hub-desc">@cat.Description</p>
                        @if (m is not null)
                        {
                            <ul class="category-hub-stats">
                                <li><strong>@m.Partners</strong> socios</li>
                                <li><strong>@m.ActiveItems</strong> activos</li>
                                <li><strong>@m.Reservations</strong> reservas</li>
                                <li class="hub-revenue">S/ @m.Revenue.ToString("N0")</li>
                            </ul>
                        }
                        <span class="category-hub-cta">Abrir panel Super Admin →</span>
                    </a>
                }
            </div>

            <section class="dash-panel mt-4 sa-features-panel">
                <h3>Funciones implementadas (todas las categorías)</h3>
                <div class="sa-features-grid">
                    <div class="sa-feature-item">✓ Métricas globales y por rubro</div>
                    <div class="sa-feature-item">✓ Crear socio + admin inicial por categoría</div>
                    <div class="sa-feature-item">✓ Editar RUC, logo, contacto y departamento</div>
                    <div class="sa-feature-item">✓ Suplantar admin o vendedor (soporte)</div>
                    <div class="sa-feature-item">✓ Suspender / reactivar socios</div>
                    <div class="sa-feature-item">✓ Ranking de recaudación</div>
                    <div class="sa-feature-item">✓ Tours: publicaciones y cupos por agencia</div>
                    <div class="sa-feature-item">✓ Comisión plataforma 10%</div>
                </div>
            </section>
        }
        else if (ActiveCategory is not null)
        {
            var catMetrics = GetCategoryMetrics(ActiveCategory.Key);

            <header class="sa-header sa-header-category">
                <div>
                    <span class="sa-cat-pill">@ActiveCategory.Icon @ActiveCategory.Label</span>
                    <h1 class="dashboard-title mb-1">Super Admin — @ActiveCategory.Label</h1>
                    <p class="text-muted mb-0">@ActiveCategory.Description</p>
                </div>
                <a class="btn btn-outline-secondary btn-sm" href="/superadmin/inicio">← Volver a Inicio</a>
            </header>

            @if (catMetrics is not null)
            {
                <div class="metrics-grid metrics-grid-compact">
                    <div class="metric-card"><span class="metric-value">@catMetrics.Partners</span><span class="metric-label">Socios</span></div>
                    <div class="metric-card"><span class="metric-value">@catMetrics.ActiveItems</span><span class="metric-label">Activos</span></div>
                    <div class="metric-card metric-warn"><span class="metric-value">@catMetrics.PendingPartners</span><span class="metric-label">Pendientes</span></div>
                    <div class="metric-card"><span class="metric-value">@catMetrics.Reservations</span><span class="metric-label">Reservas</span></div>
                    <div class="metric-card metric-highlight"><span class="metric-value">S/ @catMetrics.Revenue.ToString("N0")</span><span class="metric-label">Recaudado</span></div>
                </div>
            }

            <div class="panel-tabs sa-tabs">
                <button type="button" class="panel-tab @(mainTab == "partners" ? "active" : "")" @onclick='() => mainTab = "partners"'>Socios (@FilteredPartners.Count())</button>
                <button type="button" class="panel-tab @(mainTab == "ranking" ? "active" : "")" @onclick='() => mainTab = "ranking"'>Ranking</button>
                <button type="button" class="panel-tab @(mainTab == "create" ? "active" : "")" @onclick='() => mainTab = "create"'>+ Nuevo @ActiveCategory.Label</button>
                <button type="button" class="panel-tab @(mainTab == "config" ? "active" : "")" @onclick='() => mainTab = "config"'>Config</button>
            </div>

            @if (mainTab == "partners")
            {
                @if (!FilteredPartners.Any())
                {
                    <div class="dash-panel text-center py-4">
                        <p class="text-muted">No hay socios en @ActiveCategory.Label.</p>
                        <button type="button" class="btn btn-primary" @onclick='() => mainTab = "create"'>Crear primer perfil</button>
                    </div>
                }
                else
                {
                    <div class="partner-cards-grid">
                        @foreach (var p in FilteredPartners)
                        {
                            <article class="partner-card">
                                <div class="partner-card-top">
                                    <span class="partner-cat-badge">@ActiveCategory.Icon @ActiveCategory.Label</span>
                                    <span class="badge-status @(p.Status == "Approved" ? "ok" : "")">@p.Status</span>
                                </div>
                                <h3>@p.Name</h3>
                                <p class="partner-card-meta">RUC @p.RUC · @(string.IsNullOrWhiteSpace(p.OperatingDepartment) ? "—" : p.OperatingDepartment)</p>
                                <p class="partner-card-admin">👤 @p.AdminName<br /><small>@p.AdminEmail</small></p>
                                <div class="partner-card-stats">
                                    <span>@p.StaffCount/5 vendedores</span>
                                    <span>@p.ItemCount items</span>
                                    <span class="partner-revenue">S/ @p.Revenue.ToString("N0")</span>
                                </div>
                                <div class="partner-card-actions">
                                    <button type="button" class="btn btn-primary btn-sm" disabled="@(p.AdminUserId <= 0)"
                                            @onclick="() => ImpersonateUser(p.AdminUserId)">Entrar al panel</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => ShowStaff(p)">Equipo</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => EditPartner(p)">Editar</button>
                                    @if (p.Status != "Suspended")
                                    {
                                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => Suspend(p)">Suspender</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-outline-success btn-sm" @onclick="() => Reactivate(p)">Reactivar</button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }

                @if (staffPartner is not null)
                {
                    <section class="dash-panel mt-3">
                        <h4>Equipo — @staffPartner.Name</h4>
                        @if (staffLoading) { <p>Cargando...</p> }
                        else if (staffList.Count == 0) { <p class="text-muted">Sin vendedores.</p> }
                        else
                        {
                            @foreach (var s in staffList)
                            {
                                <div class="reservation-row">
                                    <span>@s.DisplayName — @s.Email</span>
                                    <button type="button" class="btn btn-primary btn-sm" @onclick="() => ImpersonateUser(s.UserId)">Suplantar</button>
                                </div>
                            }
                        }
                        <button type="button" class="btn btn-link btn-sm" @onclick="() => staffPartner = null">Cerrar</button>
                    </section>
                }
                @if (editPartner is not null)
                {
                    <section class="dash-panel mt-3">
                        <h4>Editar @editPartner.Name</h4>
                        <div class="admin-form-grid">
                            <input class="form-control" @bind="editForm.Name" placeholder="Nombre" />
                            <input class="form-control" @bind="editForm.RUC" placeholder="RUC" />
                            <input class="form-control" @bind="editForm.OperatingDepartment" placeholder="Departamento" />
                            <input class="form-control" @bind="editForm.LogoUrl" placeholder="Logo URL" />
                            <input class="form-control" @bind="editForm.ContactEmail" placeholder="Email" />
                            <input class="form-control" @bind="editForm.ContactPhone" placeholder="Teléfono" />
                        </div>
                        <button type="button" class="btn btn-primary btn-sm" @onclick="SaveEdit">Guardar</button>
                        <button type="button" class="btn btn-link btn-sm" @onclick="() => editPartner = null">Cancelar</button>
                    </section>
                }
            }
            else if (mainTab == "ranking")
            {
                <div class="partner-table-wrap mt-2">
                    @if (!CategoryRanking.Any()) { <p class="text-muted">Sin ranking en esta categoría.</p> }
                    else
                    {
                        <table class="partner-table">
                            <thead><tr><th>#</th><th>Socio</th><th>Recaudado</th><th>Reservas</th></tr></thead>
                            <tbody>
                                @{ var rank = 0; }
                                @foreach (var row in CategoryRanking)
                                {
                                    rank++;
                                    <tr><td>@rank</td><td>@row.Name</td><td>S/ @row.Revenue.ToString("N0")</td><td>@row.Reservations</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
            else if (mainTab == "create")
            {
                <section class="dash-panel create-profile-panel">
                    <h3>Nuevo perfil — @ActiveCategory.Label</h3>
                    <div class="admin-form-grid">
                        <input class="form-control" placeholder="Nombre comercial *" @bind="newAgency.AgencyName" />
                        <input class="form-control" placeholder="RUC *" @bind="newAgency.RUC" />
                        <input class="form-control" placeholder="Departamento operación *" @bind="newAgency.OperatingDepartment" />
                        <input class="form-control" placeholder="URL logo" @bind="newAgency.LogoUrl" />
                        <input class="form-control" placeholder="Nombre admin *" @bind="newAgency.AdminName" />
                        <input class="form-control" type="email" placeholder="Email admin *" @bind="newAgency.AdminEmail" />
                        <input class="form-control" type="password" placeholder="Contraseña admin *" @bind="newAgency.AdminPassword" />
                        <input class="form-control" placeholder="Teléfono" @bind="newAgency.ContactPhone" />
                    </div>
                    <button type="button" class="btn btn-primary" @onclick="CreateAgency" disabled="@saving">Crear @ActiveCategory.Label + admin</button>
                </section>
            }
            else
            {
                <section class="dash-panel">
                    <h3>Config — @ActiveCategory.Label</h3>
                    <ul>
                        <li>Comisión DestinoPerú: <strong>10%</strong></li>
                        <li>Tipo de socio: <strong>@ActiveCategory.Label</strong> (PartnerType @ActiveCategory.PartnerType)</li>
                        <li>Usa «Entrar al panel» para soporte sin contraseña del cliente.</li>
                    </ul>
                </section>
            }
        }
    }
</div>

@code {
    private SuperAdminDashboardDto? dashboard;
    private SuperAdminMetricsDto? metrics;
    private List<PartnerListItemDto> partners = [];
    private List<AgencyRankingDto> ranking = [];
    private List<AgencyStaffDto> staffList = [];
    private PartnerListItemDto? staffPartner;
    private PartnerListItemDto? editPartner;
    private UpdateAgencyRequest editForm = new();
    private CreateAgencyRequest newAgency = new() { AdminPassword = "Admin2026!", PartnerType = 0 };
    private string viewKey = "inicio";
    private string mainTab = "partners";
    private bool staffLoading;
    private bool loading = true;
    private bool saving;
    private string? apiWarning;

    private bool IsInicio => viewKey == "inicio";
    private SuperAdminCategory? ActiveCategory => SuperAdminCategories.All.FirstOrDefault(c => c.Key == viewKey);

    private IEnumerable<PartnerListItemDto> FilteredPartners =>
        ActiveCategory is null ? partners : partners.Where(p => p.PartnerType == ActiveCategory.PartnerType);

    private IEnumerable<AgencyRankingDto> CategoryRanking =>
        FilteredPartners
            .Select(p => ranking.FirstOrDefault(r => r.PartnerId == p.Id)
                ?? new AgencyRankingDto { PartnerId = p.Id, Name = p.Name, Revenue = p.Revenue, Reservations = 0, TourCount = p.ItemCount })
            .OrderByDescending(r => r.Revenue);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "SuperAdmin") { loading = false; return; }
        SyncViewFromUri();
        if (Nav.Uri.TrimEnd('/').Equals("/superadmin", StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo("/superadmin/inicio", replace: true);
        await LoadData();
    }

    protected override void OnParametersSet() => SyncViewFromUri();

    private void SyncViewFromUri()
    {
        if (SuperAdminCategories.IsInicioRoute(Nav.Uri))
            viewKey = "inicio";
        else
        {
            var cat = SuperAdminCategories.FromRoute(Nav.Uri);
            viewKey = cat?.Key ?? "inicio";
            if (cat is not null)
            {
                newAgency.PartnerType = cat.PartnerType;
                mainTab = "partners";
            }
        }
    }

    private CategoryMetricsDto? GetCategoryMetrics(string key) =>
        dashboard?.Categories.FirstOrDefault(c => c.Key == key);

    private async Task LoadData()
    {
        loading = true;
        apiWarning = null;
        var d = await Api.GetSuperAdminDashboardAsync();
        if (d.Success && d.Data is not null) { dashboard = d.Data; metrics = d.Data.Global; }
        else
        {
            var m = await Api.GetSuperAdminMetricsAsync();
            if (m.Success) metrics = m.Data;
            else apiWarning = m.ErrorMessage;
        }

        var p = await Api.GetSuperAdminPartnersAsync();
        if (p.Success && p.Data is not null) partners = p.Data;
        else if (string.IsNullOrEmpty(apiWarning)) apiWarning = p.ErrorMessage;

        var rk = await Api.GetSuperAdminRankingAsync();
        if (rk.Success && rk.Data is not null) ranking = rk.Data;

        loading = false;
    }

    private async Task ShowStaff(PartnerListItemDto p)
    {
        staffPartner = p;
        staffLoading = true;
        staffList = [];
        var r = await Api.GetPartnerStaffAsync(p.Id);
        if (r.Success && r.Data is not null) staffList = r.Data;
        staffLoading = false;
    }

    private void EditPartner(PartnerListItemDto p)
    {
        editPartner = p;
        editForm = new UpdateAgencyRequest { Name = p.Name, RUC = p.RUC, OperatingDepartment = p.OperatingDepartment };
    }

    private async Task SaveEdit()
    {
        if (editPartner is null) return;
        var r = await Api.UpdatePartnerAsync(editPartner.Id, editForm);
        if (r.Success) { Toast.ShowSuccess("Actualizado."); editPartner = null; await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task CreateAgency()
    {
        if (ActiveCategory is not null) newAgency.PartnerType = ActiveCategory.PartnerType;
        saving = true;
        var r = await Api.CreateAgencyAsync(newAgency);
        if (r.Success)
        {
            Toast.ShowSuccess("Perfil creado.");
            newAgency = new() { AdminPassword = "Admin2026!", PartnerType = ActiveCategory?.PartnerType ?? 0 };
            mainTab = "partners";
            await LoadData();
        }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
        saving = false;
    }

    private async Task ImpersonateUser(int userId)
    {
        if (userId <= 0) { Toast.ShowWarning("Sin administrador vinculado."); return; }
        var r = await Api.ImpersonateAsync(userId);
        if (r.Success && r.Data is not null)
        {
            await Auth.SetAuthAsync(r.Data);
            Nav.NavigateTo(r.Data.Role is "Admin" or "Agencia" ? "/admin" : r.Data.Role == "Vendedor" ? "/vendedor" : "/");
        }
        else Toast.ShowError(r.ErrorMessage ?? "No se pudo suplantar.");
    }

    private async Task Suspend(PartnerListItemDto p)
    {
        var r = await Api.SuspendPartnerAsync(p.Id, true);
        if (r.Success) { Toast.ShowSuccess("Suspendido."); await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task Reactivate(PartnerListItemDto p)
    {
        var r = await Api.SuspendPartnerAsync(p.Id, false);
        if (r.Success) { Toast.ShowSuccess("Reactivado."); await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }
}
