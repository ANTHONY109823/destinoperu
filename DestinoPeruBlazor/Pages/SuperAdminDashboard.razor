@page "/superadmin"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Super Admin - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />

    @if (!Auth.IsAuthenticated || Auth.Role != "SuperAdmin")
    {
        <div class="panel-access-denied alert alert-warning">
            Acceso restringido. Inicia sesión como Super Admin.
            <a class="btn btn-primary btn-sm ms-2" href="/login">Ingresar</a>
        </div>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando tablero maestro...</p>
    }
    else
    {
        <h1 class="dashboard-title">Gran tablero — Super Admin</h1>
        <p class="text-muted">Control total · Comisión 10% · Suplantación y gestión de agencias</p>

        @if (!string.IsNullOrEmpty(apiWarning))
        {
            <div class="alert alert-warning">@apiWarning <button class="btn btn-sm btn-outline-primary" @onclick="LoadData">Reintentar</button></div>
        }

        @if (metrics is not null)
        {
            <div class="metrics-grid">
                <div class="metric-card"><span class="metric-value">@metrics.TotalUsers</span><span class="metric-label">Usuarios</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalPartners</span><span class="metric-label">Agencias</span></div>
                <div class="metric-card metric-warn"><span class="metric-value">@metrics.PendingPartners</span><span class="metric-label">Pendientes</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalTours</span><span class="metric-label">Tours</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalReservations</span><span class="metric-label">Reservas</span></div>
                <div class="metric-card metric-highlight"><span class="metric-value">S/ @metrics.TotalRevenue.ToString("N0")</span><span class="metric-label">Recaudado</span></div>
                <div class="metric-card"><span class="metric-value">S/ @metrics.TotalCommissions.ToString("N0")</span><span class="metric-label">Comisiones 10%</span></div>
            </div>
        }

        <div class="panel-tabs">
            <button type="button" class="panel-tab @(tab == "agencies" ? "active" : "")" @onclick='() => tab = "agencies"'>Agencias (@partners.Count)</button>
            <button type="button" class="panel-tab @(tab == "ranking" ? "active" : "")" @onclick='() => tab = "ranking"'>Ranking</button>
            <button type="button" class="panel-tab @(tab == "create" ? "active" : "")" @onclick='() => tab = "create"'>Nueva agencia</button>
            <button type="button" class="panel-tab @(tab == "config" ? "active" : "")" @onclick='() => tab = "config"'>Configuración</button>
        </div>

        @if (tab == "agencies")
        {
            @if (partners.Count == 0)
            {
                <p class="text-muted">No hay agencias en la API. Redeploy la API o crea una desde «Nueva agencia».</p>
            }
            else
            {
                <div class="partner-table-wrap">
                    <table class="partner-table">
                        <thead>
                            <tr>
                                <th>Agencia</th>
                                <th>Depto.</th>
                                <th>Administrador</th>
                                <th>Vendedores</th>
                                <th>Estado</th>
                                <th>Recaudado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in partners)
                            {
                                <tr>
                                    <td><strong>@p.Name</strong><br /><small>@p.RUC</small></td>
                                    <td>@p.OperatingDepartment</td>
                                    <td>@p.AdminName<br /><small>@p.AdminEmail</small></td>
                                    <td>@p.StaffCount / 5</td>
                                    <td><span class="badge-status @(p.Status == "Approved" ? "ok" : "")">@p.Status</span></td>
                                    <td>S/ @p.Revenue.ToString("N0")</td>
                                    <td class="actions-cell">
                                        <button class="btn btn-outline-primary btn-sm" @onclick='() => ImpersonateUser(p.AdminUserId, "Admin")'>Suplantar admin</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => ShowStaff(p)">Equipo</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditPartner(p)">Editar</button>
                                        @if (p.Status != "Suspended")
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Suspend(p)">Suspender</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-success btn-sm" @onclick="() => Reactivate(p)">Reactivar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <p class="small text-muted mt-2">Suplantación: entra como admin o vendedor para soporte sin cambiar contraseñas.</p>

            @if (staffPartner is not null)
            {
                <section class="dash-panel mt-3">
                    <h4>Equipo — @staffPartner.Name</h4>
                    @if (staffLoading) { <p>Cargando...</p> }
                    else if (staffList.Count == 0) { <p class="text-muted">Sin vendedores registrados.</p> }
                    else
                    {
                        @foreach (var s in staffList)
                        {
                            <div class="reservation-row">
                                <span>@s.DisplayName (@s.StaffRole) — @s.Email</span>
                                <button class="btn btn-primary btn-sm" @onclick="() => ImpersonateUser(s.UserId, s.StaffRole)">Suplantar</button>
                            </div>
                        }
                    }
                    <button class="btn btn-link btn-sm" @onclick="() => staffPartner = null">Cerrar</button>
                </section>
            }

            @if (editPartner is not null)
            {
                <section class="dash-panel mt-3">
                    <h4>Editar @editPartner.Name</h4>
                    <div class="admin-form-grid">
                        <input class="form-control" @bind="editForm.Name" placeholder="Nombre" />
                        <input class="form-control" @bind="editForm.RUC" placeholder="RUC" />
                        <input class="form-control" @bind="editForm.OperatingDepartment" placeholder="Departamento" />
                        <input class="form-control" @bind="editForm.LogoUrl" placeholder="Logo URL" />
                        <input class="form-control" @bind="editForm.ContactEmail" placeholder="Email contacto" />
                        <input class="form-control" @bind="editForm.ContactPhone" placeholder="Teléfono" />
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="SaveEdit">Guardar</button>
                    <button class="btn btn-link btn-sm" @onclick="() => editPartner = null">Cancelar</button>
                </section>
            }
        }
        else if (tab == "ranking")
        {
            <div class="partner-table-wrap mt-3">
                @if (ranking.Count == 0) { <p class="text-muted">Sin datos de ranking.</p> }
                else
                {
                    <table class="partner-table">
                        <thead><tr><th>#</th><th>Agencia</th><th>Recaudado</th><th>Reservas</th><th>Tours</th></tr></thead>
                        <tbody>
                            @{ var rank = 0; }
                            @foreach (var row in ranking)
                            {
                                rank++;
                                <tr>
                                    <td>@rank</td>
                                    <td>@row.Name</td>
                                    <td>S/ @row.Revenue.ToString("N0")</td>
                                    <td>@row.Reservations</td>
                                    <td>@row.TourCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else if (tab == "create")
        {
            <section class="dash-panel mt-3">
                <h3>Plantilla única — nueva agencia + admin inicial</h3>
                <div class="admin-form-grid">
                    <input class="form-control" placeholder="Nombre comercial *" @bind="newAgency.AgencyName" />
                    <input class="form-control" placeholder="RUC *" @bind="newAgency.RUC" />
                    <input class="form-control" placeholder="Departamento operación *" @bind="newAgency.OperatingDepartment" />
                    <input class="form-control" placeholder="URL logo" @bind="newAgency.LogoUrl" />
                    <input class="form-control" placeholder="Nombre admin *" @bind="newAgency.AdminName" />
                    <input class="form-control" type="email" placeholder="Email admin *" @bind="newAgency.AdminEmail" />
                    <input class="form-control" type="password" placeholder="Contraseña admin *" @bind="newAgency.AdminPassword" />
                    <input class="form-control" placeholder="Teléfono" @bind="newAgency.ContactPhone" />
                </div>
                <button class="btn btn-primary" @onclick="CreateAgency" disabled="@saving">Crear agencia + admin</button>
            </section>
        }
        else
        {
            <section class="dash-panel">
                <h3>Configuración crítica (plataforma)</h3>
                <ul>
                    <li><strong>Comisión DestinoPerú:</strong> 10% fija por reserva confirmada.</li>
                    <li><strong>Términos:</strong> gestión legal pendiente de publicación en web.</li>
                    <li><strong>Mantenimiento:</strong> modo activo en Railway.</li>
                </ul>
                <p class="text-muted small">Como Super Admin puedes suplantar cualquier admin o vendedor para soporte dominical.</p>
            </section>
        }
    }
</div>

@code {
    private SuperAdminMetricsDto? metrics;
    private List<PartnerListItemDto> partners = [];
    private List<AgencyRankingDto> ranking = [];
    private List<AgencyStaffDto> staffList = [];
    private PartnerListItemDto? staffPartner;
    private PartnerListItemDto? editPartner;
    private UpdateAgencyRequest editForm = new();
    private CreateAgencyRequest newAgency = new() { AdminPassword = "Admin2026!" };
    private string tab = "agencies";
    private bool staffLoading;
    private bool loading = true;
    private bool saving;
    private string? apiWarning;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "SuperAdmin") { loading = false; return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        apiWarning = null;
        var m = await Api.GetSuperAdminMetricsAsync();
        if (m.Success) metrics = m.Data;
        else apiWarning = m.ErrorMessage;

        var p = await Api.GetSuperAdminPartnersAsync();
        if (p.Success && p.Data is not null) partners = p.Data;
        else if (string.IsNullOrEmpty(apiWarning)) apiWarning = p.ErrorMessage;

        var rk = await Api.GetSuperAdminRankingAsync();
        if (rk.Success && rk.Data is not null) ranking = rk.Data;

        loading = false;
    }

    private async Task ShowStaff(PartnerListItemDto p)
    {
        staffPartner = p;
        staffLoading = true;
        staffList = [];
        var r = await Api.GetPartnerStaffAsync(p.Id);
        if (r.Success && r.Data is not null) staffList = r.Data;
        staffLoading = false;
    }

    private void EditPartner(PartnerListItemDto p)
    {
        editPartner = p;
        editForm = new UpdateAgencyRequest { Name = p.Name, RUC = p.RUC, OperatingDepartment = p.OperatingDepartment };
    }

    private async Task SaveEdit()
    {
        if (editPartner is null) return;
        var r = await Api.UpdatePartnerAsync(editPartner.Id, editForm);
        if (r.Success) { Toast.ShowSuccess("Agencia actualizada."); editPartner = null; await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task CreateAgency()
    {
        saving = true;
        var r = await Api.CreateAgencyAsync(newAgency);
        if (r.Success)
        {
            Toast.ShowSuccess("Agencia creada.");
            newAgency = new() { AdminPassword = "Admin2026!" };
            tab = "agencies";
            await LoadData();
        }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
        saving = false;
    }

    private async Task ImpersonateUser(int userId, string expectedRole)
    {
        var r = await Api.ImpersonateAsync(userId);
        if (r.Success && r.Data is not null)
        {
            await Auth.SetAuthAsync(r.Data);
            var dest = r.Data.Role switch
            {
                "Admin" => "/admin",
                "Vendedor" => "/vendedor",
                "Agencia" => "/partner",
                _ => "/"
            };
            Nav.NavigateTo(dest);
        }
        else Toast.ShowError(r.ErrorMessage ?? "No se pudo suplantar.");
    }

    private async Task Suspend(PartnerListItemDto p)
    {
        var r = await Api.SuspendPartnerAsync(p.Id, true);
        if (r.Success) { Toast.ShowSuccess("Agencia suspendida."); await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task Reactivate(PartnerListItemDto p)
    {
        var r = await Api.SuspendPartnerAsync(p.Id, false);
        if (r.Success) { Toast.ShowSuccess("Agencia reactivada."); await LoadData(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }
}
