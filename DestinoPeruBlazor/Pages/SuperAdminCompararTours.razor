@page "/superadmin/comparar-tours"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Comparar tours - Super Admin</PageTitle>

<div class="container py-4 dashboard-page superadmin-page">
    @if (!Auth.IsAuthenticated || Auth.Role != "SuperAdmin")
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🔒" Title="Acceso restringido" Message="Esta sección es solo para el Super Admin.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else
    {
        <SuperAdminNav />
        <PageHeader Title="Comparar tours por destino"
                    Subtitle="Solo lectura · Compara precios y oferta de distintas agencias en el mismo lugar."
                    ShowBack="true" BackText="Inicio" OnBack="@(() => Nav.NavigateTo("/superadmin/inicio"))" />

        <SectionCard Title="Filtrar">
            <div class="sa-compare-filter">
                <FormField Label="Departamento o ciudad" Placeholder="Ej: Cusco, Lima, Ica" @bind-Value="filter" />
                <div class="sa-compare-filter-actions">
                    <AppButton Variant="primary" Icon="🔍" OnClick="LoadAsync">Buscar</AppButton>
                    <AppButton Variant="ghost" OnClick="ClearFilter">Ver todos</AppButton>
                </div>
            </div>
        </SectionCard>

        @if (loading)
        {
            <p class="text-muted">Cargando tours...</p>
        }
        else if (!groups.Any())
        {
            <DestinoPeruBlazor.Components.UI.EmptyState Icon="🗺️" Title="Sin tours" Message="No hay tours activos para este filtro." />
        }
        else
        {
            @foreach (var g in groups)
            {
                <SectionCard Title="@g.Key" Subtitle="@($"{g.Count()} opción{(g.Count() == 1 ? "" : "es")}")">
                    <div class="partner-table-wrap">
                        <table class="partner-table">
                            <thead>
                                <tr>
                                    <th>Tour</th>
                                    <th>Agencia</th>
                                    <th>Ubicación</th>
                                    <th>Tipo</th>
                                    <th>Precio</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in g.OrderBy(x => x.Price))
                                {
                                    <tr>
                                        <td>@t.Title</td>
                                        <td>@t.PartnerName</td>
                                        <td>@t.Location</td>
                                        <td>@t.AdventureType</td>
                                        <td><strong>S/ @t.Price.ToString("N2")</strong></td>
                                        <td>@t.Date.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </SectionCard>
            }
        }
    }
</div>

@code {
    private List<TourCompareItemDto> items = [];
    private IEnumerable<IGrouping<string, TourCompareItemDto>> groups = [];
    private string filter = "";
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.Role != "SuperAdmin") { loading = false; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        var r = await Api.GetCompareToursAsync(string.IsNullOrWhiteSpace(filter) ? null : filter.Trim());
        items = r.Success && r.Data is not null ? r.Data : [];
        groups = items.GroupBy(t => $"{t.Department} · {t.Location}".Trim(' ', '·', ' '))
            .OrderBy(g => g.Key);
        loading = false;
    }

    private async Task ClearFilter()
    {
        filter = "";
        await LoadAsync();
    }
}
