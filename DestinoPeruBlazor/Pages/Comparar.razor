@page "/comparar"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject CompareService Compare
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Comparar tours - DestinoPerú</PageTitle>

<div class="container py-4">
    <BackToHome />
    <PageHeader Title="Comparación de tours" Subtitle="Hasta 3 experiencias lado a lado: departamento, precio y cupos." />

    @if (loading)
    {
        <p>Cargando...</p>
    }
    else if (tours.Count == 0)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="⚖️" Title="Aún no comparas nada" Message="Selecciona «Comparar» en el detalle de un tour para añadirlo aquí.">
            <Action><AppButton Variant="primary" Icon="🔍" OnClick="@(() => Nav.NavigateTo("/"))">Explorar tours</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else
    {
        <div class="compare-grid">
            @foreach (var t in tours)
            {
                <AppCard Class="compare-card">
                    <span class="compare-card-dept">@t.Department · @t.AdventureType</span>
                    <h3>@t.Title</h3>
                    <p class="text-muted small mb-2">📍 @t.Location</p>
                    <p class="compare-price">S/ @t.Price.ToString("N2")</p>
                    <p class="small mb-1">Cupos: @t.AvailableCapacity / @t.Capacity</p>
                    <p class="small text-muted">@t.Date.ToString("dd/MM/yyyy")</p>
                    <AppButton Variant="primary" Block="true" OnClick="@(() => Nav.NavigateTo($"/tour/{t.Slug}"))">Reservar</AppButton>
                </AppCard>
            }
        </div>
    }
</div>

@code {
    private List<TourDto> tours = [];
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Compare.InitializeAsync();
        foreach (var slug in Compare.Slugs)
        {
            var r = await Api.GetTourBySlugAsync(slug);
            if (r.Success && r.Data is not null) tours.Add(r.Data);
        }
        loading = false;
    }
}
