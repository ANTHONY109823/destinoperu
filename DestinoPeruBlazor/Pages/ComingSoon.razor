@page "/hoteles"
@page "/restaurantes"
@page "/cafes-bar"
@inject NavigationManager Nav

<PageTitle>@Content.Title - DestinoPerú</PageTitle>

<div class="coming-soon-page">
    <div class="container">
        <BackToHome />

        <section class="coming-soon-card">
            <div class="coming-soon-badge">Próximamente</div>
            <span class="coming-soon-icon-lg">@Content.Icon</span>
            <h1>@Content.Title</h1>
            <p class="coming-soon-lead">@Content.Lead</p>
            <p class="coming-soon-invite">@Content.Invite</p>
            <div class="coming-soon-actions">
                <a class="btn-cta btn-cta-main" href="/solicitud-agencia">Enviar solicitud por correo</a>
                <a class="btn-cta btn-cta-alt" href="/">Explorar tours</a>
            </div>
        </section>
    </div>
</div>

@code {
    private CategoryContent Content => Nav.Uri.Contains("restaurantes", StringComparison.OrdinalIgnoreCase) ? Restaurant
        : Nav.Uri.Contains("cafes-bar", StringComparison.OrdinalIgnoreCase) ? CafesBar
        : Hotel;

    private static readonly CategoryContent Hotel = new(
        "Hoteles", "🏨",
        "Pronto: los mejores hoteles del Perú en un solo lugar.",
        "¿Eres hotel? Regístrate y sé de los primeros en DestinoPerú.");

    private static readonly CategoryContent Restaurant = new(
        "Restaurantes", "🍽️",
        "Pronto: experiencias gastronómicas y restaurantes destacados.",
        "¿Tienes un restaurante? Únete a nuestra red de partners verificados.");

    private static readonly CategoryContent CafesBar = new(
        "Cafés / Bar", "☕",
        "Pronto: cafés, bares y espacios para disfrutar en las principales ciudades.",
        "¿Tienes un café o bar? Súmate a DestinoPerú y llega a más viajeros.");

    private record CategoryContent(string Title, string Icon, string Lead, string Invite);
}
