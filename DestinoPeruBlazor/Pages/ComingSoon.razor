@page "/hoteles"
@page "/restaurantes"
@page "/vida-nocturna"
@inject NavigationManager Nav

<PageTitle>@Content.Title - DestinoPerú</PageTitle>

<div class="container py-4">
    <BackToHome />

    <section class="coming-soon-hero">
        <span class="coming-soon-icon">@Content.Icon</span>
        <h1>Próximamente</h1>
        <p class="coming-soon-lead">@Content.Lead</p>
        <p class="coming-soon-invite">@Content.Invite</p>
        <div class="coming-soon-actions">
            <a class="btn btn-primary" href="register">Registrar mi negocio</a>
            <a class="btn btn-outline-primary" href="/">Explorar tours</a>
        </div>
    </section>
</div>

@code {
    private CategoryContent Content => Nav.Uri.Contains("restaurantes", StringComparison.OrdinalIgnoreCase) ? Restaurant
        : Nav.Uri.Contains("vida-nocturna", StringComparison.OrdinalIgnoreCase) ? Nightlife
        : Hotel;

    private static readonly CategoryContent Hotel = new(
        "Hoteles", "🏨",
        "Pronto: los mejores hoteles del Perú en un solo lugar.",
        "¿Eres hotel? Regístrate y sé de los primeros en aparecer en DestinoPerú.");

    private static readonly CategoryContent Restaurant = new(
        "Restaurantes", "🍽️",
        "Pronto: experiencias gastronómicas y restaurantes destacados.",
        "¿Tienes un restaurante? Únete a nuestra red de partners verificados.");

    private static readonly CategoryContent Nightlife = new(
        "Vida Nocturna", "🌙",
        "Pronto: bares, discotecas y planes nocturnos en las principales ciudades.",
        "¿Ofreces vida nocturna? Contáctanos y crece con DestinoPerú.");

    private record CategoryContent(string Title, string Icon, string Lead, string Invite);
}
