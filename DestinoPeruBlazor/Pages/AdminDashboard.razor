@page "/admin"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Panel Admin Agencia - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />

    @if (Auth.Impersonating)
    {
        <div class="impersonation-banner">
            Modo soporte: actuando como <strong>@Auth.Name</strong>
            <button type="button" class="btn btn-sm btn-light ms-2" @onclick="ExitImpersonation">Volver a Super Admin</button>
        </div>
    }

    @if (!CanAccess)
    {
        <div class="panel-access-denied alert alert-warning">
            Acceso solo para administradores de agencia.
            <a class="btn btn-primary btn-sm ms-2" href="/login">Ingresar</a>
        </div>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando panel de agencia...</p>
    }
    else
    {
        <AgencyBrandHeader Profile="profile" Subtitle="Administrador de agencia · Hasta 5 vendedores · Crear tours" />

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-warning d-flex flex-wrap gap-2 align-items-center">
                @error
                <button class="btn btn-outline-primary btn-sm" @onclick="Load">Reintentar</button>
            </div>
        }

        @if (dashboard is not null)
        {
            <div class="metrics-grid">
                <div class="metric-card"><span class="metric-value">@dashboard.TotalTours</span><span class="metric-label">Tours activos</span></div>
                <div class="metric-card metric-warn"><span class="metric-value">@dashboard.PendingReservations</span><span class="metric-label">Pendientes</span></div>
                <div class="metric-card"><span class="metric-value">@dashboard.ConfirmedReservations</span><span class="metric-label">Confirmadas</span></div>
                <div class="metric-card metric-highlight"><span class="metric-value">S/ @dashboard.TotalRevenue.ToString("N0")</span><span class="metric-label">Recaudado agencia</span></div>
            </div>
        }

        <div class="panel-tabs">
            <button type="button" class="panel-tab @(tab == "team" ? "active" : "")" @onclick='() => tab = "team"'>+ Vendedores</button>
            <button type="button" class="panel-tab @(tab == "reservations" ? "active" : "")" @onclick='() => tab = "reservations"'>Reservas</button>
            <button type="button" class="panel-tab @(tab == "tours" ? "active" : "")" @onclick='() => tab = "tours"'>Nuevo tour</button>
            <button type="button" class="panel-tab @(tab == "ops" ? "active" : "")" @onclick='() => tab = "ops"'>Operaciones</button>
            <button type="button" class="panel-tab @(tab == "brand" ? "active" : "")" @onclick='() => tab = "brand"'>Marca</button>
        </div>

        @if (tab == "team")
        {
            <section class="dash-panel dash-panel-highlight">
                <h3>Crear vendedor (máx. 5)</h3>
                <p class="text-muted small">Métricas individuales por vendedor en el listado inferior.</p>
                <div class="admin-form-grid">
                    <input class="form-control" placeholder="Nombre en operaciones *" @bind="newVendor.DisplayName" />
                    <input class="form-control" type="email" placeholder="Email del vendedor *" @bind="newVendor.Email" />
                    <input class="form-control" type="password" placeholder="Contraseña *" @bind="newVendor.Password" />
                </div>
                <button class="btn btn-primary" @onclick="CreateVendor">Crear vendedor</button>

                @if (dashboard?.VendorSales.Count > 0)
                {
                    <hr />
                    <h4>Equipo y ventas</h4>
                    <div class="vendor-metrics-grid">
                        @foreach (var v in dashboard!.VendorSales)
                        {
                            <div class="vendor-metric-card">
                                <strong>@v.Name</strong>
                                <span>@v.Reservations reservas</span>
                                <span class="vendor-revenue">S/ @v.Revenue.ToString("N2")</span>
                            </div>
                        }
                    </div>
                }
            </section>
        }
        else if (tab == "reservations")
        {
            <div class="partner-table-wrap">
                @if (reservations.Count == 0) { <p class="text-muted">Sin reservas.</p> }
                else
                {
                    <table class="partner-table">
                        <thead><tr><th>Tour</th><th>Cliente</th><th>Total</th><th>Estado</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var r in reservations)
                            {
                                <tr>
                                    <td>@r.TourTitle</td>
                                    <td>@r.UserName</td>
                                    <td>S/ @r.Total.ToString("N2")</td>
                                    <td>@r.Status</td>
                                    <td>
                                        @if (r.Status == "Pending")
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="() => Approve(r.Id)">Aprobar</button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Reject(r.Id)">Rechazar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else if (tab == "tours")
        {
            <section class="dash-panel">
                <h3>Publicar tour nuevo</h3>
                <div class="admin-form-grid">
                    <input class="form-control" placeholder="Título *" @bind="newTour.Title" />
                    <input class="form-control" placeholder="Ubicación" @bind="newTour.Location" />
                    <input class="form-control" placeholder="Departamento" @bind="newTour.Department" />
                    <select class="form-select" @bind="newTour.AdventureType">
                        <option value="FullDay">Full Days</option>
                        <option value="Paquete2D1N">Paquete 2D/1N</option>
                        <option value="Cultural">Cultural</option>
                        <option value="CafeBar">Café / Bar</option>
                    </select>
                    <input type="number" class="form-control" placeholder="Precio S/" @bind="newTour.Price" />
                    <input type="number" class="form-control" placeholder="Asientos bus" @bind="newTour.Capacity" />
                    <input type="date" class="form-control" @bind="newTour.Date" />
                </div>
                <textarea class="form-control mb-2" rows="2" @bind="newTour.Description"></textarea>
                <button class="btn btn-primary btn-sm" @onclick="CreateTour">+ Publicar tour</button>
            </section>

            <section class="dash-panel mt-3">
                <h3>Mis tours (@agencyTours.Count)</h3>
                @if (agencyTours.Count == 0)
                {
                    <p class="text-muted">Aún no tienes tours. Publica el primero arriba.</p>
                }
                else
                {
                    <div class="agency-tour-manage-grid">
                        @foreach (var t in agencyTours)
                        {
                            <article class="agency-tour-manage-card @(t.IsActive ? "" : "inactive")">
                                @if (editingTourId == t.Id)
                                {
                                    <input class="form-control form-control-sm mb-1" @bind="editTitle" />
                                    <input class="form-control form-control-sm mb-1" @bind="editDepartment" />
                                    <input type="number" class="form-control form-control-sm mb-1" @bind="editPrice" />
                                    <textarea class="form-control form-control-sm mb-1" rows="2" @bind="editDescription"></textarea>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button type="button" class="btn btn-primary btn-sm" @onclick="() => SaveEditTour(t.Id)">Guardar</button>
                                        <button type="button" class="btn btn-link btn-sm" @onclick="CancelEditTour">Cancelar</button>
                                    </div>
                                }
                                else
                                {
                                    <h6>@t.Title @if (!t.IsActive) { <span class="badge bg-secondary">Inactivo</span> }</h6>
                                    <p class="small text-muted mb-1">@t.Department · S/ @t.Price.ToString("N0") · @t.AvailableCapacity/@t.Capacity cupos</p>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => StartEditTour(t)">Editar</button>
                                        @if (t.IsActive)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => DeactivateTour(t.Id)">Desactivar</button>
                                        }
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        }
        else if (tab == "ops")
        {
            <AdminOperationsPanel Dashboard="dashboard"
                                  Tours="agencyTours"
                                  PendingReservations="PendingReservations"
                                  CapacityEdits="capacityEdits"
                                  TotalSeatEdits="totalSeatEdits"
                                  CanManageTours="@(Auth.Role == "Admin")"
                                  OnApprove="Approve"
                                  OnToursChanged="Load" />
        }
        else
        {
            <section class="dash-panel">
                <h3>Perfil público y carrusel</h3>
                <div class="admin-form-grid">
                    <input class="form-control" placeholder="Nombre comercial" @bind="profileForm.Name" />
                    <input class="form-control" placeholder="URL logo" @bind="profileForm.LogoUrl" />
                    <input class="form-control" placeholder="Departamento operación" @bind="profileForm.OperatingDepartment" />
                    <input class="form-control" placeholder="Email contacto" @bind="profileForm.ContactEmail" />
                    <input class="form-control" placeholder="Teléfono" @bind="profileForm.ContactPhone" />
                </div>
                <button class="btn btn-primary" @onclick="SaveProfile">Guardar perfil</button>
                <a class="btn btn-outline-primary ms-2" href="/partner">Galería fotos / videos</a>
            </section>
        }
    }
</div>

@code {
    private AgencyProfileDto? profile;
    private AgencyDashboardDto? dashboard;
    private List<ReservationDto> reservations = [];
    private CreateVendorRequest newVendor = new();
    private CreateTourRequest newTour = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };
    private UpdateAgencyRequest profileForm = new();
    private List<AgencyTourListItemDto> agencyTours = [];
    private Dictionary<int, int> capacityEdits = new();
    private Dictionary<int, int> totalSeatEdits = new();
    private string tab = "team";
    private bool loading = true;
    private string? error;
    private int? editingTourId;
    private string editTitle = "";
    private string editDescription = "";
    private string editDepartment = "";
    private decimal editPrice;

    private List<ReservationDto> PendingReservations => reservations.Where(x => x.Status == "Pending").ToList();
    private bool CanAccess => Auth.IsAuthenticated && Auth.Role is "Admin" or "Agencia";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!CanAccess) { loading = false; return; }
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        error = null;
        var pr = await Api.GetAgencyProfileAsync();
        if (pr.Success)
        {
            profile = pr.Data;
            profileForm = new UpdateAgencyRequest
            {
                Name = profile?.Name,
                LogoUrl = profile?.LogoUrl,
                OperatingDepartment = profile?.OperatingDepartment,
                ContactEmail = profile?.ContactEmail,
                ContactPhone = profile?.ContactPhone
            };
        }

        var tr = await Api.GetAgencyToursAsync();
        if (tr.Success && tr.Data is not null)
        {
            agencyTours = tr.Data;
            capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
            totalSeatEdits = agencyTours.ToDictionary(t => t.Id, t => t.Capacity);
        }

        var d = await Api.GetAgencyDashboardAsync();
        if (d.Success) dashboard = d.Data;
        else error = d.ErrorMessage;

        var r = await Api.GetAgencyReservationsAsync();
        if (r.Success && r.Data is not null) reservations = r.Data;

        loading = false;
    }

    private async Task Approve(int id) { var res = await Api.SetReservationStatusAsync(id, "Confirmed"); if (res.Success) await Load(); else Toast.ShowError(res.ErrorMessage ?? "Error"); }
    private async Task Reject(int id) { var res = await Api.SetReservationStatusAsync(id, "Cancelled"); if (res.Success) await Load(); else Toast.ShowError(res.ErrorMessage ?? "Error"); }

    private async Task CreateVendor()
    {
        if (string.IsNullOrWhiteSpace(newVendor.DisplayName) || string.IsNullOrWhiteSpace(newVendor.Email) || newVendor.Password.Length < 6)
        { Toast.ShowWarning("Completa nombre, email y contraseña (mín. 6)."); return; }
        var res = await Api.CreateVendorAsync(newVendor);
        if (res.Success) { newVendor = new(); await Load(); Toast.ShowSuccess("Vendedor creado."); }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }

    private async Task CreateTour()
    {
        if (string.IsNullOrWhiteSpace(newTour.Title)) { Toast.ShowWarning("Título obligatorio."); return; }
        if (string.IsNullOrWhiteSpace(newTour.Description)) newTour.Description = newTour.Title;
        var res = await Api.CreateAgencyTourAsync(newTour);
        if (res.Success) { Toast.ShowSuccess("Tour publicado."); await Load(); }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }

    private async Task SaveProfile()
    {
        var r = await Api.UpdateAgencyProfileAsync(profileForm);
        if (r.Success) { profile = r.Data; Toast.ShowSuccess("Perfil actualizado."); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private void StartEditTour(AgencyTourListItemDto t)
    {
        editingTourId = t.Id;
        editTitle = t.Title;
        editDescription = t.Title;
        editDepartment = t.Department;
        editPrice = t.Price;
    }

    private void CancelEditTour() => editingTourId = null;

    private async Task SaveEditTour(int id)
    {
        var r = await Api.UpdateTourItemAsync(id, title: editTitle, description: editDescription,
            department: editDepartment, price: editPrice);
        if (r.Success) { Toast.ShowSuccess("Tour actualizado."); editingTourId = null; await Load(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task DeactivateTour(int id)
    {
        var r = await Api.DeactivateAgencyTourAsync(id);
        if (r.Success) { Toast.ShowSuccess("Tour desactivado."); await Load(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task ExitImpersonation()
    {
        if (await Auth.EndImpersonationAsync())
            Nav.NavigateTo("/superadmin/inicio");
        else
            Toast.ShowWarning("No hay sesión de Super Admin guardada. Cierra sesión e ingresa de nuevo.");
    }
}
