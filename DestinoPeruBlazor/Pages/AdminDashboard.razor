@page "/admin"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Panel Admin Agencia - DestinoPerú</PageTitle>

<div class="container py-4 dashboard-page">
    <BackToHome />

    @if (Auth.Impersonating)
    {
        <div class="impersonation-banner">
            Modo soporte: actuando como <strong>@Auth.Name</strong>
            <button type="button" class="btn btn-sm btn-light ms-2" @onclick="ExitImpersonation">Volver a Super Admin</button>
        </div>
    }

    @if (!CanAccess)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🔒" Title="Acceso restringido" Message="Esta sección es solo para administradores de agencia.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (loading)
    {
        <p class="text-muted">Cargando panel de agencia...</p>
    }
    else
    {
        <AgencyBrandHeader Profile="profile" Subtitle="Publicas tours en la categoría Tours del sitio · Hasta 5 vendedores" />

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-warning d-flex flex-wrap gap-2 align-items-center">
                @error
                <AppButton Variant="secondary" OnClick="Load">Reintentar</AppButton>
            </div>
        }

        <TabBar Tabs="Tabs" Active="tab" OnTabChange="OnTabChange" />

        @if (tab == "home")
        {
            @if (dashboard is not null)
            {
                <div class="ds-metrics-grid">
                    <MetricCard Value="@dashboard.TotalTours.ToString()" Label="Tours activos" Icon="🗺️" />
                    <MetricCard Value="@dashboard.PendingReservations.ToString()" Label="Reservas pendientes" Icon="⏳" />
                    <MetricCard Value="@dashboard.ConfirmedReservations.ToString()" Label="Reservas confirmadas" Icon="✅" />
                    <MetricCard Value="@($"S/ {dashboard.TotalRevenue.ToString("N0")}")" Label="Recaudado por la agencia" Icon="💰" />
                </div>
            }
            <SectionCard Title="Resumen" Subtitle="Bienvenido a tu panel de agencia">
                <p class="mb-2">Desde aquí gestionas tus tours, reservas, vendedores y la marca pública de tu agencia.</p>
                <div class="dash-quick-links">
                    <AppButton Variant="primary" Icon="➕" OnClick="@(() => { tab = "tours"; creatingTour = true; editingTourId = null; })">Publicar tour nuevo</AppButton>
                    <AppButton Variant="secondary" Icon="📋" OnClick="@(() => tab = "reservations")">Ver reservas</AppButton>
                </div>
            </SectionCard>
        }
        else if (tab == "tours")
        {
            @if (editingTourId is not null)
            {
                <TourEditorForm TourId="editingTourId" Model="editTourModel" Saving="savingTour" OnSave="SaveEditTourFromEditor" OnCancelEdit="CancelEditTour" />
            }
            else if (creatingTour)
            {
                <TourEditorForm Model="newTour" Saving="savingTour" OnSave="CreateTourFromEditor" OnCancelEdit="CancelCreateTour" />
            }
            else
            {
                <SectionCard Title="@($"Mis tours ({agencyTours.Count})")" Subtitle="Gestiona tus publicaciones">
                    <HeaderAction><AppButton Variant="primary" Icon="➕" OnClick="StartCreateTour">Nuevo tour</AppButton></HeaderAction>
                    <ChildContent>
                        @if (agencyTours.Count == 0)
                        {
                            <DestinoPeruBlazor.Components.UI.EmptyState Icon="🗺️" Title="Aún no tienes tours"
                                Message="Publica tu primera experiencia para que aparezca en el catálogo.">
                                <Action><AppButton Variant="primary" Icon="➕" OnClick="StartCreateTour">Publicar tour</AppButton></Action>
                            </DestinoPeruBlazor.Components.UI.EmptyState>
                        }
                        else
                        {
                            <div class="ds-tours-manage-grid">
                                @foreach (var t in agencyTours)
                                {
                                    <AppCard Class="ds-card-flush manage-tour-card">
                                        <div class="manage-tour-img" style="@ThumbStyle(t)">
                                            @if (!t.IsActive) { <span class="manage-tour-flag">Inactivo</span> }
                                        </div>
                                        <div class="manage-tour-body">
                                            <h4>@t.Title</h4>
                                            <p class="manage-tour-meta">@t.Department · @t.AdventureType</p>
                                            <div class="manage-tour-stats">
                                                <span><strong>S/ @t.Price.ToString("N0")</strong> p/persona</span>
                                                <span><strong>@t.AvailableCapacity</strong>/@t.Capacity cupos</span>
                                            </div>
                                            <div class="manage-tour-actions">
                                                <AppButton Variant="secondary" Icon="✏️" OnClick="@(() => StartEditTour(t))">Editar</AppButton>
                                                <AppButton Variant="danger" Icon="🗑️" OnClick="@(() => RequestDeleteTour(t))">Eliminar</AppButton>
                                            </div>
                                        </div>
                                    </AppCard>
                                }
                            </div>
                        }
                    </ChildContent>
                </SectionCard>
            }

            <DoubleDeleteConfirm Visible="deleteTourId.HasValue"
                                 Title="Eliminar tour"
                                 Message="¿Estás seguro de eliminar este tour? Esta acción no se puede deshacer."
                                 Step2Message="Confirmación final. Escribe ELIMINAR para confirmar el borrado."
                                 ConfirmPlaceholder="ELIMINAR"
                                 RequiredText="ELIMINAR"
                                 OnConfirm="ConfirmDeleteTour"
                                 OnCancel="CancelDeleteTour" />
        }
        else if (tab == "reservations")
        {
            <SectionCard Title="Reservas" Subtitle="Aprueba o rechaza las solicitudes de tus clientes">
                @if (reservations.Count == 0)
                {
                    <DestinoPeruBlazor.Components.UI.EmptyState Icon="📭" Title="Sin reservas todavía" Message="Cuando un cliente reserve, aparecerá aquí." />
                }
                else
                {
                    <div class="partner-table-wrap">
                        <table class="partner-table">
                            <thead><tr><th>Tour</th><th>Cliente</th><th>Total</th><th>Estado</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var r in reservations)
                                {
                                    <tr>
                                        <td>@r.TourTitle</td>
                                        <td>@r.UserName</td>
                                        <td>S/ @r.Total.ToString("N2")</td>
                                        <td><Badge Variant="@StatusVariant(r.Status)">@StatusLabel(r.Status)</Badge></td>
                                        <td>
                                            @if (r.Status == "Pending")
                                            {
                                                <div class="d-flex gap-1">
                                                    <AppButton Variant="primary" OnClick="@(() => Approve(r.Id))">Aprobar</AppButton>
                                                    <AppButton Variant="danger" OnClick="@(() => Reject(r.Id))">Rechazar</AppButton>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </SectionCard>
        }
        else if (tab == "team")
        {
            <SectionCard Title="Crear vendedor" Subtitle="Hasta 5 vendedores. Cada uno tiene métricas individuales.">
                <div class="ds-form-grid">
                    <FormField Label="Nombre en operaciones" Required="true" Placeholder="Nombre visible del vendedor" @bind-Value="newVendor.DisplayName" />
                    <FormField Label="Email del vendedor" Type="email" Required="true" Placeholder="vendedor@agencia.com" @bind-Value="newVendor.Email" />
                    <FormField Label="Contraseña" Type="password" Required="true" HelpText="Mínimo 6 caracteres." @bind-Value="newVendor.Password" />
                </div>
                <AppButton Variant="primary" Icon="➕" OnClick="CreateVendor">Crear vendedor</AppButton>
            </SectionCard>

            @if (dashboard?.VendorSales.Count > 0)
            {
                <SectionCard Title="Equipo y ventas">
                    <div class="vendor-metrics-grid">
                        @foreach (var v in dashboard!.VendorSales)
                        {
                            <div class="vendor-metric-card">
                                <strong>@v.Name</strong>
                                <span>@v.Reservations reservas</span>
                                <span class="vendor-revenue">S/ @v.Revenue.ToString("N2")</span>
                            </div>
                        }
                    </div>
                </SectionCard>
            }
        }
        else if (tab == "ops")
        {
            <AdminOperationsPanel Dashboard="dashboard"
                                  Tours="agencyTours"
                                  PendingReservations="PendingReservations"
                                  CapacityEdits="capacityEdits"
                                  TotalSeatEdits="totalSeatEdits"
                                  CanManageTours="@(Auth.Role == "Admin")"
                                  OnApprove="Approve"
                                  OnToursChanged="Load" />
        }
        else if (tab == "brand")
        {
            <SectionCard Title="Marca y perfil público" Subtitle="Estos datos se muestran a tus clientes.">
                <div class="ds-form-grid">
                    <FormField Label="Nombre comercial" Placeholder="Nombre de tu agencia" @bind-Value="profileForm.Name" />
                    <FormField Label="Departamento de operación" Placeholder="Cusco" @bind-Value="profileForm.OperatingDepartment" />
                    <FormField Label="Email de contacto" Type="email" Placeholder="contacto@agencia.com" @bind-Value="profileForm.ContactEmail" />
                    <FormField Label="Teléfono" Placeholder="+51 999 999 999" @bind-Value="profileForm.ContactPhone" />
                </div>
                <FormField Label="URL del logo" HelpText="Pega el enlace de tu logo (Cloudinary u otra fuente)." Placeholder="https://...logo.png" @bind-Value="profileForm.LogoUrl" />
                <div class="dash-quick-links">
                    <AppButton Variant="primary" Icon="💾" OnClick="SaveProfile">Guardar perfil</AppButton>
                    <AppButton Variant="secondary" Icon="🖼️" OnClick="@(() => Nav.NavigateTo("/partner"))">Galería fotos / videos</AppButton>
                </div>
            </SectionCard>
        }
    }
</div>

@code {
    private AgencyProfileDto? profile;
    private AgencyDashboardDto? dashboard;
    private List<ReservationDto> reservations = [];
    private CreateVendorRequest newVendor = new();
    private CreateTourRequest newTour = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };
    private UpdateAgencyRequest profileForm = new();
    private List<AgencyTourListItemDto> agencyTours = [];
    private Dictionary<int, int> capacityEdits = new();
    private Dictionary<int, int> totalSeatEdits = new();
    private string tab = "home";
    private bool loading = true;
    private string? error;
    private int? editingTourId;
    private int? deleteTourId;
    private bool savingTour;
    private bool creatingTour;
    private CreateTourRequest editTourModel = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };

    private List<ReservationDto> PendingReservations => reservations.Where(x => x.Status == "Pending").ToList();
    private bool CanAccess => Auth.IsAuthenticated && Auth.Role is "Admin" or "Agencia";

    private IReadOnlyList<TabBar.TabItem> Tabs =>
    [
        new("home", "Inicio", null, "🏠"),
        new("tours", "Mis tours", agencyTours.Count, "🗺️"),
        new("reservations", "Reservas", PendingReservations.Count, "📋"),
        new("team", "Vendedores", dashboard?.VendorSales.Count, "👥"),
        new("ops", "Operaciones", null, "⚙️"),
        new("brand", "Marca", null, "🏷️")
    ];

    private void OnTabChange(string key)
    {
        tab = key;
        if (key != "tours") { editingTourId = null; creatingTour = false; }
    }

    private string ThumbStyle(AgencyTourListItemDto t) => string.IsNullOrWhiteSpace(t.ImageUrl)
        ? "background: linear-gradient(135deg, var(--dp-primary), var(--dp-primary-light));"
        : $"background-image:url('{DestinoPeruBlazor.Helpers.CloudinaryHelper.Optimize(t.ImageUrl, 400)}');";

    private static string StatusVariant(string s) => s switch
    {
        "Confirmed" => "success",
        "Pending" => "warning",
        "Cancelled" => "neutral",
        _ => "info"
    };
    private static string StatusLabel(string s) => s switch
    {
        "Confirmed" => "Confirmada",
        "Pending" => "Pendiente",
        "Cancelled" => "Cancelada",
        _ => s
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!CanAccess) { loading = false; return; }
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        error = null;
        var pr = await Api.GetAgencyProfileAsync();
        if (pr.Success)
        {
            profile = pr.Data;
            profileForm = new UpdateAgencyRequest
            {
                Name = profile?.Name,
                LogoUrl = profile?.LogoUrl,
                OperatingDepartment = profile?.OperatingDepartment,
                ContactEmail = profile?.ContactEmail,
                ContactPhone = profile?.ContactPhone
            };
        }

        var tr = await Api.GetAgencyToursAsync();
        if (tr.Success && tr.Data is not null)
        {
            agencyTours = tr.Data;
            capacityEdits = agencyTours.ToDictionary(t => t.Id, t => t.AvailableCapacity);
            totalSeatEdits = agencyTours.ToDictionary(t => t.Id, t => t.Capacity);
        }

        var d = await Api.GetAgencyDashboardAsync();
        if (d.Success) dashboard = d.Data;
        else error = d.ErrorMessage;

        var r = await Api.GetAgencyReservationsAsync();
        if (r.Success && r.Data is not null) reservations = r.Data;

        loading = false;
    }

    private async Task Approve(int id) { var res = await Api.SetReservationStatusAsync(id, "Confirmed"); if (res.Success) await Load(); else Toast.ShowError(res.ErrorMessage ?? "Error"); }
    private async Task Reject(int id) { var res = await Api.SetReservationStatusAsync(id, "Cancelled"); if (res.Success) await Load(); else Toast.ShowError(res.ErrorMessage ?? "Error"); }

    private async Task CreateVendor()
    {
        if (string.IsNullOrWhiteSpace(newVendor.DisplayName) || string.IsNullOrWhiteSpace(newVendor.Email) || newVendor.Password.Length < 6)
        { Toast.ShowWarning("Completa nombre, email y contraseña (mín. 6)."); return; }
        var res = await Api.CreateVendorAsync(newVendor);
        if (res.Success) { newVendor = new(); await Load(); Toast.ShowSuccess("Vendedor creado."); }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
    }

    private void StartCreateTour()
    {
        newTour = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };
        creatingTour = true;
        editingTourId = null;
    }

    private void CancelCreateTour() => creatingTour = false;

    private async Task CreateTourFromEditor(CreateTourRequest model)
    {
        if (string.IsNullOrWhiteSpace(model.Title)) { Toast.ShowWarning("Título obligatorio."); return; }
        if (string.IsNullOrWhiteSpace(model.Description)) model.Description = model.Title;
        savingTour = true;
        newTour = model;
        var res = await Api.CreateAgencyTourAsync(newTour);
        if (res.Success)
        {
            Toast.ShowSuccess("Tour publicado.");
            newTour = new() { Date = DateTime.Today.AddDays(7), AdventureType = "FullDay", Capacity = 20 };
            creatingTour = false;
            await Load();
        }
        else Toast.ShowError(res.ErrorMessage ?? "Error");
        savingTour = false;
    }

    private async Task SaveProfile()
    {
        var r = await Api.UpdateAgencyProfileAsync(profileForm);
        if (r.Success) { profile = r.Data; Toast.ShowSuccess("Perfil actualizado."); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
    }

    private async Task StartEditTour(AgencyTourListItemDto t)
    {
        creatingTour = false;
        editingTourId = t.Id;
        var full = await Api.GetTourAsync(t.Id);
        if (full.Success && full.Data is not null)
        {
            var d = full.Data;
            editTourModel = new CreateTourRequest
            {
                Title = d.Title,
                Description = d.Description,
                Price = d.Price,
                Location = d.Location,
                Department = d.Department,
                AdventureType = d.AdventureType,
                Date = d.Date,
                Capacity = d.Capacity,
                ImageUrl = d.ImageUrl,
                PuntoPartida = d.PuntoPartida,
                PuntoRetorno = d.PuntoRetorno,
                HoraSalida = d.HoraSalida,
                DuracionAproximada = d.DuracionAproximada,
                Itinerario = d.Itinerario,
                QueIncluye = d.QueIncluye,
                QueNoIncluye = d.QueNoIncluye,
                QueLlevar = d.QueLlevar,
                Galeria = d.Galeria
            };
        }
        else
        {
            editTourModel = new CreateTourRequest
            {
                Title = t.Title,
                Description = t.Title,
                Department = t.Department,
                Price = t.Price,
                AdventureType = t.AdventureType,
                ImageUrl = t.ImageUrl
            };
        }
    }

    private void CancelEditTour() => editingTourId = null;

    private async Task SaveEditTourFromEditor(CreateTourRequest model)
    {
        if (!editingTourId.HasValue) return;
        savingTour = true;
        var r = await Api.UpdateTourDetailsAsync(editingTourId.Value, model);
        if (r.Success) { Toast.ShowSuccess("Tour actualizado."); editingTourId = null; await Load(); }
        else Toast.ShowError(r.ErrorMessage ?? "Error");
        savingTour = false;
    }

    private void RequestDeleteTour(AgencyTourListItemDto t) => deleteTourId = t.Id;
    private void CancelDeleteTour() => deleteTourId = null;

    private async Task ConfirmDeleteTour()
    {
        if (!deleteTourId.HasValue) return;
        var id = deleteTourId.Value;
        var r = await Api.DeleteTourAsync(id);
        if (r.Success)
        {
            Toast.ShowSuccess("Tour eliminado.");
            deleteTourId = null;
            if (editingTourId == id) editingTourId = null;
            await Load();
        }
        else Toast.ShowError(r.ErrorMessage ?? "No se pudo eliminar.");
    }

    private async Task ExitImpersonation()
    {
        if (await Auth.EndImpersonationAsync())
            Nav.NavigateTo("/superadmin/inicio");
        else
            Toast.ShowWarning("No hay sesión de Super Admin guardada. Cierra sesión e ingresa de nuevo.");
    }
}
