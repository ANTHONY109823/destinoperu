@page "/tour/{Id:int}"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>@(tour?.Title ?? "Tour") - DestinoPeru</PageTitle>

<div class="container py-4">
    @if (loading)
    {
        <p>Cargando...</p>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (tour is not null)
    {
        <div class="tour-detail">
            <div class="tour-detail-header" style="@HeaderStyle">
                <h1>@tour.Title</h1>
                <p>@tour.Location · @tour.Date.ToString("dddd, dd MMMM yyyy")</p>
            </div>
            <div class="row mt-4">
                <div class="col-lg-8">
                    <p class="lead">@tour.Description</p>
                    <ul class="tour-meta-list">
                        <li><strong>Agencia:</strong> @tour.AgencyName</li>
                        <li><strong>Precio:</strong> S/ @tour.Price.ToString("N2") por persona</li>
                        <li><strong>Cupos:</strong> @tour.Capacity</li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <div class="booking-card">
                        <h4>Reservar</h4>
                        @if (!Auth.IsAuthenticated)
                        {
                            <p>Inicia sesion para reservar.</p>
                            <a class="btn btn-primary w-100" href="login">Ingresar</a>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Cantidad</label>
                                <input type="number" class="form-control" min="1" max="@tour.Capacity" @bind="quantity" />
                            </div>
                            <p class="booking-total">Total: <strong>S/ @((tour.Price * quantity).ToString("N2"))</strong></p>
                            @if (!string.IsNullOrEmpty(bookingError))
                            {
                                <div class="alert alert-danger py-2">@bookingError</div>
                            }
                            <button class="btn btn-primary w-100" disabled="@booking" @onclick="Reserve">
                                @(booking ? "Procesando..." : "Reservar ahora")
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private TourDto? tour;
    private bool loading = true;
    private bool booking;
    private int quantity = 1;
    private string? error;
    private string? bookingError;

    private string HeaderStyle => tour is null || string.IsNullOrEmpty(tour.ImageUrl)
        ? "background: linear-gradient(135deg, #9a3412, #c2410c)"
        : $"background-image: url('{tour.ImageUrl}')";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        var response = await Api.GetTourAsync(Id);
        if (response.Success && response.Data is not null)
            tour = response.Data;
        else
            error = response.ErrorMessage ?? "Tour no encontrado.";
        loading = false;
    }

    private async Task Reserve()
    {
        if (tour is null) return;
        booking = true;
        bookingError = null;
        var result = await Api.CreateReservationAsync(new CreateReservationRequest { TourId = tour.Id, Quantity = quantity });
        if (result.Success && result.Data is not null)
            Nav.NavigateTo($"checkout/{result.Data.Id}");
        else
            bookingError = result.ErrorMessage;
        booking = false;
    }
}
