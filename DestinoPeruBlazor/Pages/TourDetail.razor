@page "/tour/{Slug}"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Components
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject CartService Cart
@inject CompareService Compare
@inject ToastService Toast
@inject NavigationManager Nav
@inject FavoritesService Favorites

@if (tour is not null)
{
    <MetaTags Title="@(string.IsNullOrWhiteSpace(tour.MetaTitle) ? tour.Title : tour.MetaTitle)"
              Description="@(string.IsNullOrWhiteSpace(tour.MetaDescription) ? tour.Description : tour.MetaDescription)"
              ImageUrl="@ActiveImage" />
}

<PageTitle>@(tour?.Title ?? "Tour") - DestinoPerú</PageTitle>

<div class="container py-4 tour-detail-page">
    <div class="tour-detail-back">
        <AppButton Variant="ghost" Icon="←" OnClick="GoBack">Volver a experiencias</AppButton>
    </div>

    @if (loading)
    {
        <div class="tour-detail-loading">
            <div class="tour-gallery-main skeleton-block"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🧭" Title="No encontramos este tour" Message="@error">
            <Action><AppButton Variant="primary" OnClick="GoBack">Ver otras experiencias</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (tour is not null)
    {
        <div class="tour-detail">
            <div class="tour-gallery">
                <div class="tour-gallery-main" style="@MainImageStyle"></div>
                @if (galleryUrls.Count > 1)
                {
                    <div class="tour-gallery-thumbs">
                        @for (var i = 0; i < galleryUrls.Count; i++)
                        {
                            var idx = i;
                            <button type="button"
                                    class="tour-gallery-thumb @(idx == selectedImage ? "active" : "")"
                                    style="background-image: url('@CloudinaryHelper.Optimize(galleryUrls[idx], 400)')"
                                    @onclick="() => selectedImage = idx"
                                    aria-label="Ver imagen @(idx + 1)"></button>
                        }
                    </div>
                }
            </div>

            <header class="tour-detail-header">
                <div class="tour-detail-tags">
                    <span class="tour-detail-dept-inline">@tour.Department · @tour.AdventureType</span>
                    @if (IsNew) { <Badge Variant="info">Nuevo</Badge> }
                </div>
                <h1 class="tour-detail-title">@tour.Title</h1>
                <p class="tour-detail-sub">
                    📍 @tour.Location · @tour.Date.ToString("dddd, dd 'de' MMMM yyyy", EsPe)
                </p>
                <div class="tour-detail-rating-row">
                    @if (ReviewCount > 0)
                    {
                        <Rating Value="@ReviewAverage" Max="5" />
                        <span class="tour-detail-opiniones">@ReviewAverage.ToString("0.0") · @ReviewCount opinión@(ReviewCount == 1 ? "" : "es")</span>
                    }
                    else
                    {
                        <span class="tour-detail-opiniones">Aún sin opiniones</span>
                    }
                </div>
            </header>

            <div class="row mt-4 g-4">
                <div class="col-lg-8">
                    <SectionCard Title="Sobre esta experiencia">
                        <p class="tour-detail-desc">@tour.Description</p>
                    </SectionCard>

                    @if (HasLogistics)
                    {
                        <SectionCard Title="Datos clave">
                            <div class="tour-keyfacts">
                                @if (!string.IsNullOrWhiteSpace(tour.PuntoPartida))
                                {
                                    <div class="tour-keyfact"><span class="tour-keyfact-ico">📍</span><div><span class="tour-keyfact-label">Punto de partida</span><span class="tour-keyfact-value">@tour.PuntoPartida</span></div></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(tour.HoraSalida))
                                {
                                    <div class="tour-keyfact"><span class="tour-keyfact-ico">🕐</span><div><span class="tour-keyfact-label">Hora de salida</span><span class="tour-keyfact-value">@tour.HoraSalida</span></div></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(tour.PuntoRetorno))
                                {
                                    <div class="tour-keyfact"><span class="tour-keyfact-ico">↩️</span><div><span class="tour-keyfact-label">Punto de retorno</span><span class="tour-keyfact-value">@tour.PuntoRetorno</span></div></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(tour.DuracionAproximada))
                                {
                                    <div class="tour-keyfact"><span class="tour-keyfact-ico">⏱️</span><div><span class="tour-keyfact-label">Duración</span><span class="tour-keyfact-value">@tour.DuracionAproximada</span></div></div>
                                }
                            </div>
                        </SectionCard>
                    }

                    @if (tour.Itinerario.Count > 0)
                    {
                        <SectionCard Title="Itinerario">
                            <ol class="tour-timeline">
                                @foreach (var step in tour.Itinerario)
                                {
                                    <li class="tour-timeline-item">
                                        <span class="tour-timeline-hour">@step.Hora</span>
                                        <div>
                                            <strong>@step.Titulo</strong>
                                            @if (!string.IsNullOrWhiteSpace(step.Descripcion))
                                            {
                                                <p class="mb-0 text-muted small">@step.Descripcion</p>
                                            }
                                        </div>
                                    </li>
                                }
                            </ol>
                        </SectionCard>
                    }

                    @if (tour.QueIncluye.Count > 0 || tour.QueNoIncluye.Count > 0)
                    {
                        <SectionCard Title="¿Qué incluye?">
                            <div class="tour-incl-grid">
                                @if (tour.QueIncluye.Count > 0)
                                {
                                    <ul class="tour-feature-list tour-feature-yes">
                                        @foreach (var x in tour.QueIncluye) { <li><span class="tfl-ico">✓</span>@x</li> }
                                    </ul>
                                }
                                @if (tour.QueNoIncluye.Count > 0)
                                {
                                    <ul class="tour-feature-list tour-feature-no">
                                        @foreach (var x in tour.QueNoIncluye) { <li><span class="tfl-ico">✕</span>@x</li> }
                                    </ul>
                                }
                            </div>
                        </SectionCard>
                    }

                    @if (tour.QueLlevar.Count > 0)
                    {
                        <SectionCard Title="Qué llevar">
                            <ul class="tour-feature-list tour-feature-bring">
                                @foreach (var x in tour.QueLlevar) { <li><span class="tfl-ico">🎒</span>@x</li> }
                            </ul>
                        </SectionCard>
                    }

                    <SectionCard Title="@($"Opiniones de viajeros{(ReviewCount > 0 ? $" ({ReviewCount})" : "")}")">
                        @if (reviews?.CanReview == true)
                        {
                            <div class="review-form">
                                <h4 class="review-form-title">Cuéntanos tu experiencia</h4>
                                <div class="review-stars-pick" role="radiogroup" aria-label="Calificación">
                                    @for (var s = 1; s <= 5; s++)
                                    {
                                        var star = s;
                                        <button type="button" class="review-star-btn @(star <= reviewRating ? "on" : "")"
                                                @onclick="() => reviewRating = star" aria-label="@star estrellas">★</button>
                                    }
                                </div>
                                <FormField Type="textarea" Placeholder="¿Qué tal estuvo el tour, el guía, la puntualidad?" @bind-Value="reviewComment" Rows="3" />
                                @if (!string.IsNullOrEmpty(reviewError)) { <div class="alert alert-danger py-2">@reviewError</div> }
                                <AppButton Variant="primary" Loading="submittingReview" OnClick="SubmitReview">Publicar reseña</AppButton>
                            </div>
                        }
                        else if (reviews?.AlreadyReviewed == true)
                        {
                            <p class="text-muted">✓ Ya compartiste tu opinión sobre este tour. ¡Gracias!</p>
                        }
                        else if (!Auth.IsAuthenticated)
                        {
                            <p class="text-muted">Inicia sesión y reserva este tour para dejar tu opinión.</p>
                        }

                        @if (reviews is { Items.Count: > 0 })
                        {
                            <ul class="review-list">
                                @foreach (var rv in reviews.Items)
                                {
                                    <li class="review-item">
                                        <div class="review-item-head">
                                            <span class="review-item-avatar">@(string.IsNullOrWhiteSpace(rv.UserName) ? "?" : rv.UserName.Trim()[..1].ToUpperInvariant())</span>
                                            <div>
                                                <strong>@rv.UserName</strong>
                                                <span class="review-item-stars">@(new string('★', rv.Rating))<span class="review-item-stars-off">@(new string('★', 5 - rv.Rating))</span></span>
                                            </div>
                                            <span class="review-item-date">@rv.CreatedAt.ToString("dd MMM yyyy", EsPe)</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(rv.Comment))
                                        {
                                            <p class="review-item-comment">@rv.Comment</p>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else if (reviews?.CanReview != true && reviews?.AlreadyReviewed != true)
                        {
                            <DestinoPeruBlazor.Components.UI.EmptyState Icon="⭐"
                                Title="Aún no hay opiniones"
                                Message="Sé el primero en compartir tu experiencia después de reservar este tour." />
                        }
                    </SectionCard>

                    <SectionCard Title="Agencia operadora">
                        <div class="tour-agency-block">
                            <div class="tour-agency-avatar" aria-hidden="true">@AgencyInitial</div>
                            <div class="tour-agency-info">
                                <div class="tour-agency-name">
                                    @if (HasAgencyProfile)
                                    {
                                        <a class="tour-agency-name-link" href="@AgencyProfileHref">@tour.PartnerName</a>
                                    }
                                    else
                                    {
                                        @tour.PartnerName
                                    }
                                    <Badge Variant="success" Icon="✓">Verificada</Badge>
                                </div>
                                @if (ReviewCount > 0)
                                {
                                    <Rating Value="@ReviewAverage" Max="5" />
                                }
                                <div class="tour-agency-links">
                                    @if (HasAgencyProfile)
                                    {
                                        <a class="tour-agency-link" href="@AgencyProfileHref">Ver perfil de la agencia →</a>
                                    }
                                    <a class="tour-agency-link" href="@AgencyExploreHref">Más experiencias en @tour.Department →</a>
                                </div>
                            </div>
                        </div>
                    </SectionCard>
                </div>

                <div class="col-lg-4">
                    <div class="booking-card booking-card-sticky">
                        <div class="booking-price-row">
                            <span class="booking-price">S/ @tour.Price.ToString("N0")</span>
                            <span class="booking-price-unit">por persona</span>
                        </div>
                        <p class="booking-stock">
                            @if (tour.AvailableCapacity > 0)
                            {
                                <span class="booking-stock-ok">@tour.AvailableCapacity cupos disponibles</span>
                            }
                            else
                            {
                                <span class="booking-stock-out">Sin cupos disponibles</span>
                            }
                        </p>

                        @if (!Auth.IsAuthenticated)
                        {
                            <p class="text-muted small mb-2">Inicia sesión para reservar tu lugar.</p>
                            <AppButton Variant="primary" Block="true" OnClick="GoToLogin">Ingresar para reservar</AppButton>
                        }
                        else
                        {
                            <div class="booking-field">
                                <FormField Label="Cantidad de personas" Type="number" @bind-Value="quantityStr" />
                            </div>
                            <div class="booking-total-row">
                                <span>Total</span>
                                <strong>S/ @((tour.Price * quantity).ToString("N2"))</strong>
                            </div>
                            <p class="booking-points">Ganas ~@((int)(tour.Price * quantity * 0.01m)) puntos loyalty</p>
                            @if (!string.IsNullOrEmpty(bookingError))
                            {
                                <div class="alert alert-danger py-2">@bookingError</div>
                            }
                            <AppButton Variant="primary" Block="true" Loading="booking" Disabled="@(tour.AvailableCapacity <= 0)" OnClick="Reserve">Reservar ahora</AppButton>
                            @if (Auth.Role == "Cliente")
                            {
                                <div class="booking-secondary">
                                    <AppButton Variant="secondary" Block="true" Icon="🛒" OnClick="AddToCart">Agregar al carrito</AppButton>
                                </div>
                            }
                            <div class="booking-secondary">
                                <AppButton Variant="ghost" Block="true" OnClick="ToggleCompare">@(inCompare ? "Quitar de comparación" : "Añadir a comparación")</AppButton>
                            </div>
                        }
                        <div class="booking-secondary">
                            <AppButton Variant="ghost" Block="true" Icon="@(isFav ? "♥" : "♡")" OnClick="ToggleFavorite">@(isFav ? "Guardado en favoritos" : "Guardar en favoritos")</AppButton>
                        </div>

                        <div class="booking-trust">
                            <span>📱 Pago seguro Yape / Plin</span>
                            <span>✓ Agencia verificada</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private TourDto? tour;
    private List<string> galleryUrls = [];
    private int selectedImage;
    private bool loading = true;
    private bool booking;
    private string quantityStr = "1";
    private string? error;
    private string? bookingError;
    private bool inCompare;
    private bool isFav;

    private TourReviewsDto? reviews;
    private int reviewRating = 5;
    private string reviewComment = "";
    private bool submittingReview;
    private string? reviewError;

    private static readonly System.Globalization.CultureInfo EsPe = new("es-PE");

    private int quantity => int.TryParse(quantityStr, out var q) && q > 0 ? q : 1;
    private double ReviewAverage => reviews?.Average ?? 0;
    private int ReviewCount => reviews?.Count ?? 0;
    private bool IsNew => tour is not null && (DateTime.UtcNow - tour.CreatedAt).TotalDays <= 21;
    private bool HasLogistics => tour is not null &&
        (!string.IsNullOrWhiteSpace(tour.PuntoPartida) || !string.IsNullOrWhiteSpace(tour.PuntoRetorno)
         || !string.IsNullOrWhiteSpace(tour.HoraSalida) || !string.IsNullOrWhiteSpace(tour.DuracionAproximada));
    private string AgencyInitial => string.IsNullOrWhiteSpace(tour?.PartnerName) ? "?" : tour!.PartnerName.Trim()[..1].ToUpperInvariant();

    private string AgencyExploreHref => string.IsNullOrWhiteSpace(tour?.Department)
        ? "/"
        : $"/?dept={Uri.EscapeDataString(tour!.Department)}";

    private bool HasAgencyProfile => !string.IsNullOrWhiteSpace(tour?.PartnerSlug);
    private string AgencyProfileHref => HasAgencyProfile ? $"/agencia/{tour!.PartnerSlug}" : "/";

    private string ActiveImage => galleryUrls.Count > 0
        ? CloudinaryHelper.Optimize(galleryUrls[selectedImage], 1200)
        : "";

    private string MainImageStyle => string.IsNullOrEmpty(ActiveImage)
        ? "background: linear-gradient(135deg, #004D40, #00695C)"
        : $"background-image: url('{ActiveImage}')";

    private void GoBack() => Nav.NavigateTo("/");
    private void GoToLogin() => Nav.NavigateTo("/login");

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Compare.InitializeAsync();
        inCompare = Compare.Slugs.Contains(Slug);
        await Favorites.InitializeAsync();
        var response = await Api.GetTourBySlugAsync(Slug);
        if (response.Success && response.Data is not null)
        {
            tour = response.Data;
            galleryUrls = TourGalleryHelper.GetGalleryUrls(tour.ImageUrl, tour.Slug, tour.Galeria).ToList();
            isFav = Favorites.IsFavorite(string.IsNullOrEmpty(tour.Slug) ? tour.Id.ToString() : tour.Slug);
            await LoadReviews();
        }
        else error = response.ErrorMessage ?? "Tour no encontrado.";
        loading = false;
    }

    private async Task LoadReviews()
    {
        if (tour is null) return;
        var r = await Api.GetTourReviewsAsync(tour.Id);
        if (r.Success && r.Data is not null) reviews = r.Data;
    }

    private async Task SubmitReview()
    {
        if (tour is null) return;
        reviewError = null;
        if (reviewRating is < 1 or > 5) { reviewError = "Elige de 1 a 5 estrellas."; return; }
        submittingReview = true;
        var result = await Api.CreateReviewAsync(new CreateReviewRequest
        {
            TourId = tour.Id, Rating = reviewRating, Comment = reviewComment
        });
        submittingReview = false;
        if (result.Success)
        {
            Toast.ShowSuccess("¡Gracias por tu reseña!");
            reviewComment = "";
            await LoadReviews();
        }
        else reviewError = result.ErrorMessage;
    }

    private async Task ToggleFavorite()
    {
        if (tour is null) return;
        var key = string.IsNullOrEmpty(tour.Slug) ? tour.Id.ToString() : tour.Slug;
        isFav = await Favorites.ToggleAsync(key);
        Toast.ShowSuccess(isFav ? "Guardado en favoritos." : "Quitado de favoritos.");
    }

    private async Task Reserve()
    {
        if (tour is null) return;
        booking = true; bookingError = null;
        var result = await Api.CreateReservationAsync(new CreateReservationRequest { TourId = tour.Id, Quantity = quantity });
        if (result.Success && result.Data is not null)
            Nav.NavigateTo($"/checkout/{result.Data.Id}");
        else
            bookingError = result.ErrorMessage;
        booking = false;
    }

    private async Task AddToCart()
    {
        if (tour is null) return;
        await Cart.InitializeAsync();
        await Cart.AddAsync(tour, quantity);
        Toast.ShowSuccess("Añadido al carrito.");
    }

    private async Task ToggleCompare()
    {
        if (tour is null) return;
        await Compare.InitializeAsync();
        var ok = await Compare.ToggleAsync(tour.Slug);
        if (!ok) { Toast.ShowWarning("Máximo 3 tours en comparación."); return; }
        inCompare = Compare.Slugs.Contains(tour.Slug);
        Toast.ShowSuccess(inCompare ? "Añadido a comparar." : "Quitado de comparar.");
    }
}
