@page "/checkout/{ReservationId:int}"
@page "/mis-reservas"
@using DestinoPeruBlazor.Models
@using DestinoPeruBlazor.Services
@using DestinoPeruBlazor.Helpers
@using DestinoPeruBlazor.Components.UI
@inject ApiService Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Pago - Destino Peru</PageTitle>

<div class="container py-4">
    <BackToHome />
    @if (!Auth.IsAuthenticated)
    {
        <DestinoPeruBlazor.Components.UI.EmptyState Icon="🔒" Title="Inicia sesión" Message="Debes iniciar sesión para continuar.">
            <Action><AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo("/login"))">Ingresar</AppButton></Action>
        </DestinoPeruBlazor.Components.UI.EmptyState>
    }
    else if (loading) { <p>Cargando...</p> }
    else if (IsReservationsList)
    {
        @if (loyalty is not null)
        {
            <div class="loyalty-banner mb-3">
                <strong>@loyalty.Points</strong> puntos disponibles ·
                <a href="/fidelidad">ver fidelidad</a> ·
                <a href="/carrito">carrito</a>
            </div>
        }
        <PageHeader Title="Mis reservas" Subtitle="Revisa el estado de tus reservas y completa los pagos pendientes." />
        @if (reservations.Count == 0)
        {
            <DestinoPeruBlazor.Components.UI.EmptyState Icon="📭" Title="No tienes reservas" Message="Explora el catálogo y reserva tu primera experiencia.">
                <Action><AppButton Variant="primary" Icon="🔍" OnClick="@(() => Nav.NavigateTo("/"))">Buscar tours</AppButton></Action>
            </DestinoPeruBlazor.Components.UI.EmptyState>
        }
        else
        {
            <SectionCard Title="@($"Tus reservas ({reservations.Count})")">
                @foreach (var r in reservations)
                {
                    <div class="cart-row">
                        <div>
                            <strong>@r.TourTitle</strong>
                            <p class="mb-0 text-muted small">@r.TourLocation · @r.TourDate.ToString("dd/MM/yyyy") · <Badge Variant="@StatusVariant(r.Status)">@StatusLabel(r.Status)</Badge></p>
                            @if (r.LoyaltyPointsEarned > 0) { <small class="text-success">+@r.LoyaltyPointsEarned pts</small> }
                        </div>
                        <div class="cart-row-actions">
                            <span class="cart-row-price">S/ @r.Total.ToString("N2")</span>
                            @if (r.Status == "Pending")
                            {
                                <AppButton Variant="primary" OnClick="@(() => Nav.NavigateTo($"/checkout/{r.Id}"))">Pagar</AppButton>
                            }
                        </div>
                    </div>
                }
            </SectionCard>
        }
    }
    else if (reservation is not null)
    {
        <PageHeader Title="Pago" Subtitle="Completa tu reserva en un par de pasos." ShowBack="true" BackText="Mis reservas" OnBack="@(() => Nav.NavigateTo("/mis-reservas"))" />
        <div class="checkout-card">
            <h4>@reservation.TourTitle</h4>
            <p class="text-muted">@reservation.TourLocation · @reservation.Quantity persona(s)</p>
            <p class="checkout-total">Total: <strong>S/ @reservation.Total.ToString("N2")</strong></p>

            <FormField Label="Método de pago" Type="select" @bind-Value="paymentMethod" Disabled="awaitingVoucher">
                <option value="Tarjeta">Tarjeta (simulado)</option>
                <option value="Yape">Yape QR</option>
                <option value="Plin">Plin QR</option>
            </FormField>

            @if (IsWallet && !paid && !awaitingVoucher)
            {
                <div class="qr-box">
                    <div class="qr-placeholder">QR @paymentMethod</div>
                    <p class="small text-muted">Escanea y paga. Luego sube tu voucher.</p>
                    <FormField Label="Referencia / N° de operación" Placeholder="Ej. 0123456789" @bind-Value="qrReference" />
                </div>
            }

            @if (awaitingVoucher && currentPayment is not null)
            {
                <div class="voucher-upload">
                    <p><strong>Paso 2:</strong> Sube captura del pago @paymentMethod</p>
                    <InputFile OnChange="OnVoucherSelected" accept="image/*" />
                    @if (!string.IsNullOrEmpty(voucherPreview))
                    {
                        <img src="@voucherPreview" class="upload-preview mt-2" alt="Voucher" />
                    }
                    <div class="mt-3">
                        <AppButton Variant="primary" Loading="uploadingVoucher" OnClick="SubmitVoucher">Enviar voucher a la agencia</AppButton>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(paid || voucherSent ? "alert-success" : "alert-danger") mt-3">@message</div>
            }

            @if (!paid && !awaitingVoucher)
            {
                <div class="mt-2">
                    <AppButton Variant="primary" Block="true" Loading="paying" OnClick="Pay">@(IsWallet ? "Generar pago QR" : "Pagar ahora")</AppButton>
                </div>
            }
            else if (paid || voucherSent)
            {
                <div class="mt-2">
                    <AppButton Variant="secondary" OnClick="@(() => Nav.NavigateTo("/"))">Volver a tours</AppButton>
                </div>
            }
        </div>
    }
    else { <div class="alert alert-danger">@message</div> }
</div>

@code {
    [Parameter] public int ReservationId { get; set; }

    private ReservationDto? reservation;
    private List<ReservationDto> reservations = [];
    private LoyaltyDto? loyalty;
    private PaymentDto? currentPayment;
    private bool loading = true;
    private bool paying;
    private bool paid;
    private bool awaitingVoucher;
    private bool voucherSent;
    private bool uploadingVoucher;
    private string paymentMethod = "Tarjeta";
    private string? qrReference;
    private string? message;
    private string? voucherPreview;
    private string? voucherUrl;

    private bool IsReservationsList => Nav.Uri.Contains("mis-reservas", StringComparison.OrdinalIgnoreCase);
    private bool IsWallet => paymentMethod is "Yape" or "Plin";

    private static string StatusVariant(string s) => s switch
    {
        "Confirmed" or "Paid" => "success",
        "Pending" => "warning",
        "Cancelled" => "neutral",
        _ => "info"
    };
    private static string StatusLabel(string s) => s switch
    {
        "Confirmed" => "Confirmada",
        "Paid" => "Pagada",
        "Pending" => "Pendiente",
        "Cancelled" => "Cancelada",
        _ => s
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsAuthenticated) { loading = false; return; }
        if (Auth.Role == "Cliente")
        {
            var ly = await Api.GetLoyaltyAsync();
            if (ly.Success) loyalty = ly.Data;
        }

        var result = await Api.GetUserReservationsAsync();
        if (result.Success && result.Data is not null)
        {
            reservations = result.Data;
            if (!IsReservationsList)
            {
                reservation = reservations.FirstOrDefault(r => r.Id == ReservationId);
                if (reservation is null) message = "Reserva no encontrada.";
            }
        }
        else message = result.ErrorMessage;
        loading = false;
    }

    private async Task Pay()
    {
        if (reservation is null) return;
        paying = true; message = null;
        var result = await Api.ProcessPaymentAsync(new CreatePaymentRequest
        {
            ReservationId = reservation.Id,
            Method = paymentMethod,
            QrReference = IsWallet ? qrReference : null
        });
        if (result.Success && result.Data is not null)
        {
            currentPayment = result.Data;
            if (IsWallet)
            {
                awaitingVoucher = true;
                message = "Pago QR iniciado. Sube tu voucher para validacion del partner.";
            }
            else
            {
                paid = true;
                message = "Pago exitoso. ID: " + result.Data.TransactionId;
                reservation.Status = "Paid";
            }
        }
        else message = result.ErrorMessage;
        paying = false;
    }

    private async Task OnVoucherSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        await using var stream = file.OpenReadStream(5 * 1024 * 1024);
        var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;
        var up = await Api.UploadImageAsync(ms, file.Name, "vouchers");
        if (up.Success)
        {
            voucherUrl = up.Data;
            voucherPreview = CloudinaryHelper.Optimize(voucherUrl, 400);
        }
        else message = up.ErrorMessage;
    }

    private async Task SubmitVoucher()
    {
        if (currentPayment is null || string.IsNullOrEmpty(voucherUrl)) { message = "Sube una imagen primero."; return; }
        uploadingVoucher = true;
        var r = await Api.SubmitVoucherAsync(new SubmitVoucherRequest { PaymentId = currentPayment.Id, VoucherUrl = voucherUrl });
        if (r.Success) { voucherSent = true; message = "Voucher enviado. La agencia validara tu pago."; }
        else message = r.ErrorMessage;
        uploadingVoucher = false;
    }
}
